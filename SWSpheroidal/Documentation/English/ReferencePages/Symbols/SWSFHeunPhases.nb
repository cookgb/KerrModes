Cell[CellGroupData[{
Cell["SWSFHeunPhases", "ObjectName",
 CellID->547718981,ExpressionUUID->"eb8eafce-6415-4628-bf02-fb09c3ac3b58"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"68ff0767-2d28-4791-b7c2-b65e161be305"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["SWSFHeunPhases",
    BaseStyle->"Link",
    ButtonData->"paclet:SWSpheroidal/ref/SWSFHeunPhases"], "[", 
   RowBox[{
    StyleBox["s", "TI"], ",", 
    StyleBox["m", "TI"], ",", 
    StyleBox["l", "TI"], ",", 
    StyleBox["c", "TI"], ",", 
    StyleBox["Alm",
     FontSlant->"Italic"]}], "]"}]], "InlineFormula",ExpressionUUID->
  "0fae4cb5-3a4d-4758-836a-0413fb4de4ad"],
 "\[LineSeparator]returns a pair of phase factors which will implement the \
Cook-Wang SL phase choice for the spin-weighted spheroidal function with \
spin-weight ",
 Cell[BoxData[
  StyleBox["s", "TI"]], "InlineFormula",ExpressionUUID->
  "a18ea36a-e9eb-472d-bd34-501704d96215"],
 ", azimuthal index ",
 Cell[BoxData[
  StyleBox["m", "TI"]], "InlineFormula",ExpressionUUID->
  "a2e867c0-1374-4ce4-b682-8457b9657490"],
 ",  harmonic index ",
 Cell[BoxData[
  StyleBox["l", "TI"]], "InlineFormula",ExpressionUUID->
  "317e6dd3-1df2-4958-a032-fa8f7e49ac57"],
 ", oblateness parameter ",
 Cell[BoxData[
  StyleBox["c", "TI"]], "InlineFormula",ExpressionUUID->
  "742caec0-d2bc-47bb-82ef-16d84f04100b"],
 ", and eigenvalue  ",
 Cell[BoxData[
  StyleBox["Alm", "TI"]], "InlineFormula",ExpressionUUID->
  "94883ceb-dfe4-4207-995c-83046dac98c4"],
 "."
}], "Usage",
 CellChangeTimes->{{3.981559826961833*^9, 3.981559876607259*^9}, {
  3.981559915978093*^9, 3.981559926242897*^9}, {3.981559966712256*^9, 
  3.981559970456505*^9}, {3.981560014504517*^9, 3.9815600185370398`*^9}, {
  3.981560184254497*^9, 3.9815602071215763`*^9}},
 CellID->689677231,ExpressionUUID->"cebad275-4045-49d6-a2f2-ee03b9a65c9a"],

Cell[TextData[{
 "Returns the 2-element list ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"phase1", ",", "phase2"}], "}"}]], "InlineFormula",
  FormatType->StandardForm,ExpressionUUID->
  "426cdf80-8747-4c6e-a15c-457727c025ec"],
 StyleBox[".", "InlineCode"]
}], "Notes",
 CellChangeTimes->{{3.981561037575365*^9, 3.981561079154687*^9}, 
   3.981561154496283*^9},
 CellID->1024555186,ExpressionUUID->"19a4de94-4662-4127-9620-ff4fcaf28497"],

Cell[TextData[{
 "The function ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["SWSFHeun",
    BaseStyle->"Link",
    ButtonData->"paclet:SWSpheroidal/ref/SWSFHeun"], "[", 
   RowBox[{"norm", ",", "s", ",", "m", ",", "c", ",", "Alm", ",", "x"}], 
   "]"}]], "InlineFormula",ExpressionUUID->
  "2d65e5f9-0659-4b9c-b33e-ee685a1b9af5"],
 " computes a spin-weighted spheroidal function over the range ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"-", "1"}], "\[LessEqual]", "x", "\[LessEqual]", "1"}], 
   TraditionalForm]], "InlineMath",ExpressionUUID->
  "84cf6d15-8a92-4e00-91f2-213d89a665ac"],
 ", but evaluates it using one confluent Heun function over the range ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"-", "1"}], "\[LessEqual]", "x", "<", "0"}], TraditionalForm]], 
  "InlineMath",ExpressionUUID->"545ffa9f-5269-4750-817c-fa274721c9f5"],
 " and a different  confluent Heun function over the range ",
 Cell[BoxData[
  FormBox[
   RowBox[{"0", "\[LessEqual]", "x", "\[LessEqual]", "1"}], TraditionalForm]],
   "InlineMath",ExpressionUUID->"8577f57c-738f-474b-a824-3d9360b288dd"],
 ".   ",
 Cell[BoxData[
  ButtonBox["SWSFHeunPhases",
   BaseStyle->"Link",
   ButtonData->"paclet:SWSpheroidal/ref/SWSFHeunPhases"]], "InlineFormula",
  ExpressionUUID->"66c78f24-f4e0-40cc-a890-11c78440f423"],
 " returns a 2-element list containing the proper phase factor for each \
range.  In the returned list, ",
 Cell[BoxData[
 "phase1"], "InlineFormula",ExpressionUUID->
  "035a039f-80d4-4a52-81ab-40bd83d18a11"],
 " applies to the range ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"-", "1"}], "\[LessEqual]", "x", "<", "0"}], TraditionalForm]], 
  "InlineMath",ExpressionUUID->"f21dedc4-ee1a-456f-944d-27655a72a335"],
 " and ",
 Cell[BoxData[
 "phase2"], "InlineFormula",ExpressionUUID->
  "c092282a-f21f-409e-a2f0-cdbaeea3ce2c"],
 " applies to the range ",
 Cell[BoxData[
  FormBox[
   RowBox[{" ", 
    FormBox[
     RowBox[{"0", "\[LessEqual]", "x", "\[LessEqual]", "1"}],
     TraditionalForm]}], TraditionalForm]], "InlineMath",ExpressionUUID->
  "e8199bb5-a755-403b-a770-7fbfa66031ff"],
 "."
}], "Notes",
 CellChangeTimes->{{3.981560297293116*^9, 3.981560423113493*^9}, {
   3.9815604678206367`*^9, 3.98156077573628*^9}, {3.9815611075679407`*^9, 
   3.9815611939014263`*^9}, 3.981561793485042*^9, {3.981562829598304*^9, 
   3.981562843689369*^9}},
 CellID->873441664,ExpressionUUID->"6e686082-6f70-494f-8e07-e79053108a3c"],

Cell[TextData[{
 "The Cook-Wang SL phase choice chooses the phase of the spin-weighted \
spheroidal function based on the spin-weighted spherical function ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[InvisiblePrefixScriptBase]", "s"], 
    SubscriptBox["S", 
     StyleBox[
      RowBox[{"\[ScriptL]", 
       StyleBox["m", "TI"]}]]]}], TraditionalForm]], "InlineMath",
  ExpressionUUID->"2d61cc93-4152-4433-8b85-2e3e01c21f36"],
 "."
}], "Notes",
 CellChangeTimes->{{3.981560297293116*^9, 3.981560458730194*^9}, 
   3.981560732444821*^9},
 CellID->876123880,ExpressionUUID->"e054533c-1ae5-4fd3-b382-a4a620a04c9c"],

