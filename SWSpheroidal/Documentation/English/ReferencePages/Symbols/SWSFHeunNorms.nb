Notebook[{

Cell[CellGroupData[{
Cell["SWSFHeunNorms", "ObjectName",
 CellID->26540110,ExpressionUUID->"6176e340-ec11-4fd7-acdd-37e529d5a843"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"14bced26-6f76-4227-b72d-bc33e20197a4"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["SWSFHeunNorms",
    BaseStyle->"Link",
    ButtonData->"paclet:SWSpheroidal/ref/SWSFHeunNorms"], "[", 
   RowBox[{
    StyleBox["s", "TI"], ",", 
    StyleBox["m", "TI"], ",", 
    StyleBox["c", "TI"], ",", 
    StyleBox["Alm",
     FontSlant->"Italic"]}], "]"}]], "InlineFormula",ExpressionUUID->
  "65d259ac-2475-4e10-b5a2-0f80247a0099"],
 " \[LineSeparator]returns a pair of normalization factors which will \
properly normalize the spin-weighted spheroidal function with spin-weight ",
 Cell[BoxData[
  StyleBox["s", "TI"]], "InlineFormula",ExpressionUUID->
  "e5eaab05-5926-420f-8301-8c15d67d413b"],
 ", azimuthal index ",
 Cell[BoxData[
  StyleBox["m", "TI"]], "InlineFormula",ExpressionUUID->
  "ed5a3ab1-4977-488a-87ca-f3e68a9e514f"],
 ",  oblateness parameter ",
 Cell[BoxData[
  StyleBox["c", "TI"]], "InlineFormula",ExpressionUUID->
  "ebbc142a-19a6-42bf-90f1-67d235cf434e"],
 ", and eigenvalue  ",
 Cell[BoxData[
  StyleBox["Alm", "TI"]], "InlineFormula",ExpressionUUID->
  "834346d2-5883-4806-9061-008a721fc9a8"],
 "."
}], "Usage",
 CellChangeTimes->{{3.981561650469686*^9, 3.981561737191387*^9}},
 CellID->923539403,ExpressionUUID->"76d30913-8a96-4a25-baf1-3ab455387f5c"],

Cell[TextData[{
 "Returns the 2-element list ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"norm1", ",", "norm2"}], "}"}]], "InlineFormula",
  FormatType->StandardForm,ExpressionUUID->
  "51847847-f373-43cb-81a1-22b19f25c277"],
 StyleBox[".", "InlineCode"]
}], "Notes",
 CellChangeTimes->{{3.981561037575365*^9, 3.981561079154687*^9}, 
   3.981561154496283*^9, {3.981561758553093*^9, 3.9815617639217463`*^9}},
 CellID->1024555186,ExpressionUUID->"0899d356-9d20-4113-af3f-8a240204e3c4"],

Cell[TextData[{
 "The function ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["SWSFHeun",
    BaseStyle->"Link",
    ButtonData->"paclet:SWSpheroidal/ref/SWSFHeun"], "[", 
   RowBox[{"norm", ",", "s", ",", "m", ",", "c", ",", "Alm", ",", "x"}], 
   "]"}]], "InlineFormula",ExpressionUUID->
  "fd8702fb-3f24-4ce4-b8f7-2a20fa022151"],
 " computes a spin-weighted spheroidal function over the range ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"-", "1"}], "\[LessEqual]", "x", "\[LessEqual]", "1"}], 
   TraditionalForm]], "InlineMath",ExpressionUUID->
  "c29cb85c-a63c-4d39-a23e-7618861281c8"],
 ", but evaluates it using one confluent Heun function over the range ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"-", "1"}], "\[LessEqual]", "x", "<", "0"}], TraditionalForm]], 
  "InlineMath",ExpressionUUID->"7e1bada4-04c4-4fc1-9863-d208faaf250a"],
 " and a different  confluent Heun function over the range ",
 Cell[BoxData[
  FormBox[
   RowBox[{"0", "\[LessEqual]", "x", "\[LessEqual]", "1"}], TraditionalForm]],
   "InlineMath",ExpressionUUID->"1727a077-f123-42c8-828d-66bc93fed96f"],
 ".   SWSFHeunNorms returns a 2-element list containing the proper \
normalization factor for each range.  In the returned list, ",
 Cell[BoxData[
 "norm1"], "InlineFormula",ExpressionUUID->
  "d2a99af5-ccd1-4b33-bd10-ebaaaa09f885"],
 " applies to the range ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"-", "1"}], "\[LessEqual]", "x", "<", "0"}], TraditionalForm]], 
  "InlineMath",ExpressionUUID->"b685cfe0-863e-48be-b496-5212814c1382"],
 " and ",
 Cell[BoxData[
 "norm2"], "InlineFormula",ExpressionUUID->
  "6a1caab2-e212-4c83-af37-6a8c3d79b506"],
 " applies to the range ",
 Cell[BoxData[
  FormBox[
   RowBox[{" ", 
    FormBox[
     RowBox[{"0", "\[LessEqual]", "x", "\[LessEqual]", "1"}],
     TraditionalForm]}], TraditionalForm]], "InlineMath",ExpressionUUID->
  "29a8446d-7725-4160-b630-07c201bea5f3"],
 "."
}], "Notes",
 CellChangeTimes->{{3.981560297293116*^9, 3.981560423113493*^9}, {
   3.9815604678206367`*^9, 3.98156077573628*^9}, {3.9815611075679407`*^9, 
   3.9815611939014263`*^9}, {3.981561800460403*^9, 3.9815618243145657`*^9}, 
