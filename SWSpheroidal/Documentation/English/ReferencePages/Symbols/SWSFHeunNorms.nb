eigensolution with m=1, s=2, and  ",
 Cell[BoxData[
  RowBox[{"c", "=", 
   FractionBox["1", "2"]}]],ExpressionUUID->
  "69c3bbd2-b3a6-4163-884b-fcd0042a23b4"],
