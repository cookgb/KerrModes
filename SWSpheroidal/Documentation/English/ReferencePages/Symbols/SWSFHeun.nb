Notebook[{

Cell[CellGroupData[{
Cell["SWSFHeun", "ObjectName",
 CellID->1212822750,ExpressionUUID->"2e0d3a2e-5110-49b1-bb31-360162ac2a81"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"202bba73-351c-47f2-b87b-4b77b82988e2"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["SWSFHeun",
    BaseStyle->"Link",
    ButtonData->"paclet:SWSpheroidal/ref/SWSFHeun"], "[", 
   RowBox[{
    StyleBox["norm", "TI"], ",", 
    StyleBox["s", "TI"], ",", 
    StyleBox["m", "TI"], ",", 
    StyleBox["c", "TI"], ",", 
    StyleBox["Alm",
     FontSlant->"Italic"], ",", 
    StyleBox["x", "TI"]}], "]"}]], "InlineFormula",ExpressionUUID->
  "76ca3f75-af38-4854-854d-32813f0fb6ba"],
 " \[LineSeparator]evaluates the spin-weighted spheroidal function with \
spin-weight ",
 Cell[BoxData[
  StyleBox["s", "TI"]], "InlineFormula",ExpressionUUID->
  "23a5b4ca-84c0-4312-a224-a30644405794"],
 ", azimuthal index ",
 Cell[BoxData[
  StyleBox["m", "TI"]], "InlineFormula",ExpressionUUID->
  "6b373f96-fb2f-4548-bc2d-1502944a0f81"],
 ",  oblateness parameter ",
 Cell[BoxData[
  StyleBox["c", "TI"]], "InlineFormula",ExpressionUUID->
  "e57c5cf6-202a-4473-9186-de8685014752"],
 ", and eigenvalue  ",
 Cell[BoxData[
  StyleBox["Alm", "TI"]], "InlineFormula",ExpressionUUID->
  "faa58671-c2ba-444e-b543-7c05475fec00"],
 "  at location x in the range ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"-", "1"}], "\[LessEqual]", "x", "\[LessEqual]", "1"}], 
   TraditionalForm]], "InlineMath",ExpressionUUID->
  "a8e2aa9b-d593-4fb3-880e-1a6eff8b5ad0"],
 ".  ",
 Cell[BoxData[
  StyleBox["norm", "TI"]], "InlineFormula",ExpressionUUID->
  "e76f967d-2971-4d84-9267-22aa9291ac34"],
 " is a 2-element list which provides the desired normalization and phase \
choices for the function."
}], "Usage",
 CellChangeTimes->{{3.9815624803342857`*^9, 3.981562531158931*^9}, {
  3.981562561384624*^9, 3.981562726837117*^9}},
 CellID->1618101111,ExpressionUUID->"9355270f-2164-45be-a7ef-61e6dcc7ffa0"],

Cell[TextData[{
 "The function ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["SWSFHeun",
    BaseStyle->"Link",
    ButtonData->"paclet:SWSpheroidal/ref/SWSFHeun"], "[", 
   RowBox[{"norm", ",", "s", ",", "m", ",", "c", ",", "Alm", ",", "x"}], 
   "]"}]], "InlineFormula",ExpressionUUID->
  "99386721-15ea-424b-a244-46179e28cc61"],
 " computes a spin-weighted spheroidal function over the range ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"-", "1"}], "\[LessEqual]", "x", "\[LessEqual]", "1"}], 
   TraditionalForm]], "InlineMath",ExpressionUUID->
  "c555b185-0638-464f-aa24-783144f54559"],
 ", but evaluates it using one confluent Heun function over the range ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"-", "1"}], "\[LessEqual]", "x", "<", "0"}], TraditionalForm]], 
  "InlineMath",ExpressionUUID->"ac835325-4f54-4a05-abbf-52b198aeeeb9"],
 " and a different  confluent Heun function over the range ",
 Cell[BoxData[
  FormBox[
   RowBox[{"0", "\[LessEqual]", "x", "\[LessEqual]", "1"}], TraditionalForm]],
   "InlineMath",ExpressionUUID->"7f0bbb90-2c01-4947-a065-5b56b2eb279f"],
 ".   The ",
 Cell[BoxData["norm"], "InlineFormula",
  FormatType->StandardForm,ExpressionUUID->
  "8fade792-d50d-4938-aefd-b5815cb09e3c"],
 " argument to ",
 Cell[BoxData[
  ButtonBox["SWSFHeun",
   BaseStyle->"Link",
   ButtonData->"paclet:SWSpheroidal/ref/SWSFHeun"]], "InlineFormula",
  ExpressionUUID->"31ac471f-2e12-4188-a49d-d0c71edcc715"],
 " is a 2-element list ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"norm1", ",", "norm2"}], "}"}]], "InlineFormula",
  FormatType->StandardForm,ExpressionUUID->
  "5752afd0-5527-4b2d-993a-16f0f6edc392"],
 " containing the proper normalization and phase choices for each range.  In \
the returned list, ",
 Cell[BoxData[
 "norm1"], "InlineFormula",ExpressionUUID->
  "bf031d85-2f74-4138-8488-860d40ec4f90"],
 " applies to the range ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"-", "1"}], "\[LessEqual]", "x", "<", "0"}], TraditionalForm]], 
  "InlineMath",ExpressionUUID->"36497381-2438-48ea-95c1-ae5697e2d096"],
 " and ",
 Cell[BoxData[
 "norm2"], "InlineFormula",ExpressionUUID->
  "3263a6c0-00e8-4689-846f-123ea541d459"],
 " applies to the range ",
 Cell[BoxData[
  FormBox[
   RowBox[{" ", 
    FormBox[
     RowBox[{"0", "\[LessEqual]", "x", "\[LessEqual]", "1"}],
     TraditionalForm]}], TraditionalForm]], "InlineMath",ExpressionUUID->
  "da165918-fc90-407f-bc81-7e5f38f7d215"],
 "."
}], "Notes",
 CellChangeTimes->{{3.981560297293116*^9, 3.981560423113493*^9}, {
   3.9815604678206367`*^9, 3.98156077573628*^9}, {3.9815611075679407`*^9, 
   3.9815611939014263`*^9}, {3.981561800460403*^9, 3.9815618243145657`*^9}, 
   3.981562097577381*^9, {3.9815628118229437`*^9, 3.981562812587405*^9}, {
   3.981562864765091*^9, 3.98156286476513*^9}, {3.981562919933394*^9, 
   3.981562975553982*^9}, {3.981563006447218*^9, 3.981563059097837*^9}},
 CellID->873441664,ExpressionUUID->"be111137-a18d-4cfe-912d-87582a51386c"],

Cell[TextData[{
 "The values of ",
 Cell[BoxData["norm"], "InlineFormula",
  FormatType->StandardForm,ExpressionUUID->
  "8c55a31f-6967-4d8a-ba6c-cc81f63a35cf"],
 " can be  expensive to compute and are usually precomputed prior to \
evaluation of SWSFHeun at any value of ",
 Cell[BoxData[
  FormBox[
   FormBox["x",
    TraditionalForm], TraditionalForm]], "InlineMath",ExpressionUUID->
  "50e5bf96-515d-4d34-b80e-2f9910754f51"],
 ".  Usually, the element-wise produce of the normalization factor returned \
by ",
 Cell[BoxData[
  ButtonBox["SWSFHeunNorms",
   BaseStyle->"Link",
   ButtonData->"paclet:SWSpheroidal/ref/SWSFHeunNorms"]], "InlineFormula",
  ExpressionUUID->"7dd8151b-e996-449a-aa73-98eacd67267a"],
 ", and the phase factor returned by ",
 Cell[BoxData[
  ButtonBox["SWSFHeunPhases",
   BaseStyle->"Link",
   ButtonData->"paclet:SWSpheroidal/ref/SWSFHeunPhases"]], "InlineFormula",
  ExpressionUUID->"9b4baff0-b458-4f2a-a337-5c57c0e26344"],
 ", is used for ",
 Cell[BoxData["norm"], "InlineFormula",
  FormatType->StandardForm,ExpressionUUID->
  "b8491535-23c0-4b73-a270-4d20b4c5600d"],
 " ."
}], "Notes",
 CellChangeTimes->{{3.981563087311819*^9, 3.981563315307468*^9}},
