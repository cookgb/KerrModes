Notebook[{

Cell[CellGroupData[{
Cell["SLCorrectPiDiscontinuity", "ObjectName",
 CellChangeTimes->{{3.920709673586071*^9, 3.9207096792908382`*^9}, {
  3.9827429173469973`*^9, 3.982742917564497*^9}},
 CellID->2065184800,ExpressionUUID->"46972c97-b26d-4d86-871a-f629086d45a7"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"8cf2c2c6-9e94-4820-b128-3ed1cc1c4ac0"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["SLCorrectPiDiscontinuity",
    BaseStyle->"Link",
    ButtonData->"paclet:SWSpheroidal/ref/SLCorrectPiDiscontinuity"], "[", 
   RowBox[{
    StyleBox["m", "TI"], ",", 
    StyleBox["s", "TI"], ",", 
    StyleBox["L", "TI"], ",", 
    StyleBox["SWdat", "TI"], ",", 
    StyleBox["SLPhase", "TI"]}], "]"}]], "InlineFormula",ExpressionUUID->
  "0fc751b0-a113-424c-82d2-ee158c68204b"],
 "\[LineSeparator]returns a list of complex phase values which have been \
corrected to to remove phase-angle discontinuities of \[Pi]."
}], "Usage",
 CellChangeTimes->{
  3.920364274463379*^9, {3.9203650520511312`*^9, 3.920365061298957*^9}, {
   3.920385947311941*^9, 3.920385948964199*^9}, {3.9207097016340437`*^9, 
   3.920709735022242*^9}, {3.92070979539255*^9, 3.920709795392623*^9}, {
   3.9207099387198687`*^9, 3.9207099387199373`*^9}, {3.982742988059116*^9, 
   3.9827430049115267`*^9}},
 CellID->1078796233,ExpressionUUID->"0fb12190-81db-4de4-bcf1-467d7d6405e5"],

Cell[TextData[{
 "The returned value is a ",
 ButtonBox["List",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/List"],
 " of complex numbers of unit magnitude."
}], "Notes",
 CellChangeTimes->{{3.920376109430717*^9, 3.920376117958131*^9}, 
   3.9203761757315083`*^9, {3.982744850446385*^9, 3.982744850447281*^9}},
 CellID->2062725854,ExpressionUUID->"f9d6eb52-7af6-4894-8a93-b260f41d0ca8"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   StyleBox["m", "TI"], TraditionalForm]], "InlineCode",ExpressionUUID->
  "ccdf2eab-e0ed-4c81-9368-cf0b754993ea"],
 " is the azimuthal index of the spin-weighted spheroidal functions \
represented by the expansion coefficients contained in SWdat."
}], "Notes",
 CellChangeTimes->{{3.92037632589952*^9, 3.9203764042783527`*^9}, 
   3.920376660756606*^9, {3.92037670829364*^9, 3.920376720324493*^9}},
 CellID->1499976174,ExpressionUUID->"06fa19fc-7fff-44c2-83d1-e74755761d7e"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   StyleBox["s", "TI"], TraditionalForm]], "InlineCode",ExpressionUUID->
  "43512b70-81cd-4fd3-9e3b-7eb71eb1ced0"],
 " is the spin weight index of the spin-weighted spheroidal functions \
represented by the expansion coefficients contained in SWdat."
}], "Notes",
 CellChangeTimes->{{3.920376408940796*^9, 3.920376424954174*^9}, {
  3.920376724332129*^9, 3.9203767357841883`*^9}},
 CellID->342198517,ExpressionUUID->"a772f224-f916-431e-a057-fe885755a2fc"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   StyleBox["L", "TI"], TraditionalForm]], "InlineCode",ExpressionUUID->
  "14ea6293-4f12-4818-9b6c-94c7d73d440f"],
 " is the zero-based harmonic index related to the standard harmonic index \
\[ScriptL] by ",
 Cell[BoxData[
  StyleBox["L", "TI"]], "InlineFormula",ExpressionUUID->
  "432dc7e0-3b4d-4a61-ab4c-8497864895f7"],
 " = \[ScriptL] - Max(|m|,|s|).  Each spin-weighted spheroidal function \
represented by the list of expansion coefficients in SWdat is assumed to be \
associated with the same harmonic index ",
 Cell[BoxData[
  FormBox[
   StyleBox["L", "TI"], TraditionalForm]], "InlineCode",ExpressionUUID->
  "13af2e29-e9d0-4fca-ba3a-b4659e62bc7c"],
 ". "
}], "Notes",
 CellChangeTimes->{{3.920376442488471*^9, 3.920376591673118*^9}, {
  3.920376680573494*^9, 3.920376702262974*^9}},
 CellID->100102736,ExpressionUUID->"5d0535a9-2d41-4380-82e1-ff3ec478f26e"],

Cell[TextData[{
 StyleBox["SWdat", "TI"],
 " is a List of spectral expansion coefficient ",
 ButtonBox["List",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/List"],
 "s as returned by ",
 Cell[BoxData[
  ButtonBox["SpinWeightedSpheroidal",
   BaseStyle->"Link",
   ButtonData->"paclet:SWSpheroidal/ref/SpinWeightedSpheroidal"]], 
  "InlineFormula",ExpressionUUID->"d2c247b4-8105-4d04-80a8-80fd48e69e7e"],
 ", ",
 Cell[BoxData[
  ButtonBox["AngularSpectralRoot",
   BaseStyle->"Link",
   ButtonData->"paclet:SWSpheroidal/ref/AngularSpectralRoot"]], 
  "InlineFormula",ExpressionUUID->"5a625df0-2d9b-48f5-bdff-90e238674deb"],
 ", or ",
 Cell[BoxData[
  ButtonBox["AngularSpectralRootIndex",
   BaseStyle->"Link",
   ButtonData->"paclet:SWSpheroidal/ref/AngularSpectralRootIndex"]], 
  "InlineFormula",ExpressionUUID->"10d918cb-42e1-4f5b-84ef-5dab8b75724d"],
 "."
}], "Notes",
 CellChangeTimes->{{3.920376193562951*^9, 3.92037621810467*^9}},
 CellID->584540360,ExpressionUUID->"57ce9885-665b-4d9f-a853-3fc932d2e276"],

Cell[TextData[{
 StyleBox["SLPhase", "TI"],
 " is a ",
 ButtonBox["List",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/List"],
 " of complex numbers of unit magnitude where each element of the ",
 ButtonBox["List",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/List"],
 " is the value returned by ",
 Cell[BoxData[
  ButtonBox["SWSFfixphase",
   BaseStyle->"Link",
   ButtonData->"paclet:SWSpheroidal/ref/SWSFfixphase"]], "InlineFormula",
  FormatType->StandardForm,ExpressionUUID->
  "4233c860-5ab5-43c3-a64f-e39e624d14be"],
 " from the corresponding element of SWdat."
}], "Notes",
 CellChangeTimes->{{3.920376081715959*^9, 3.92037610252234*^9}, {
   3.920376135803176*^9, 3.920376189527145*^9}, {3.920376241518075*^9, 
   3.920376274043178*^9}, 3.920376837424945*^9, {3.982744882054212*^9, 
   3.982744933220551*^9}, {3.9827449653738747`*^9, 3.982744969518347*^9}},
 CellID->802748876,ExpressionUUID->"f6e7e2b1-699e-4d27-aa75-90b55db7163b"],

Cell[TextData[{
 "It is assumed that ",
 StyleBox["SLPhase", "TI"],
 " has been computed with the SphericalLimit ",
 ButtonBox["PhaseChoice",
  BaseStyle->"Link",
  ButtonData->"paclet:SWSpheroidal/ref/PhaseChoice"],
 "."
}], "Notes",
 CellChangeTimes->{{3.920376081715959*^9, 3.92037610252234*^9}, {
   3.920376135803176*^9, 3.920376189527145*^9}, {3.920376241518075*^9, 
