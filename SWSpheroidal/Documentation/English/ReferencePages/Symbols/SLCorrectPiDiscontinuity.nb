  3.920385176978166*^9}},
 CellID->1165304359,ExpressionUUID->"d67c6d21-eace-4fb6-bd19-55cb054e3009"],

Cell[BoxData[
 RowBox[{
  RowBox[{"SWdat", "=", 
   RowBox[{"Flatten", "[", 
    RowBox[{
     RowBox[{"Take", "[", 
      RowBox[{"data", ",", "All", ",", 
       RowBox[{"-", "1"}], ",", 
       RowBox[{"{", "4", "}"}]}], "]"}], ",", "2"}], "]"}]}], ";"}]], "Input",\

