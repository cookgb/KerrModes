Cell[TextData[{
 "Compute the first 25 spin-weighted spheroidal eigensolutions for m=0, s=-2, \
and along c=\[LeftBracketingBar]c\[RightBracketingBar]",
 Cell[BoxData[
  SuperscriptBox["e", 
   RowBox[{
    RowBox[{"-", "\[ImaginaryI]"}], 
    FractionBox["\[Pi]", "3"]}]]], "InlineFormula",ExpressionUUID->
  "2d9f9640-caef-4097-8665-226641156943"],
 "."
}], "ExampleText",
 CellChangeTimes->{{3.9203845041048517`*^9, 3.9203846406669273`*^9}, {
  3.9827432907838707`*^9, 3.9827432926671352`*^9}},
 CellID->1080647755,ExpressionUUID->"052d2727-855f-436f-bade-aec08af8f68d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"data", " ", "=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"SpinWeightedSpheroidal", "[", 
      RowBox[{"0", ",", 
       RowBox[{"-", "2"}], ",", 
       RowBox[{"c", " ", 
        RowBox[{"Exp", "[", 
         RowBox[{
          RowBox[{"-", "\[ImaginaryI]"}], " ", 
          RowBox[{"\[Pi]", "/", "3"}]}], "]"}]}], ",", "25"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"c", ",", "0.0", ",", "5.0", ",", "0.05"}], "}"}]}], "]"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.920377125112896*^9, 3.920377234262979*^9}, {
  3.920377753515625*^9, 3.920377787835544*^9}, {3.920377848548559*^9, 
  3.9203778643202467`*^9}, {3.920379290368834*^9, 3.920379293831477*^9}, {
  3.920379369505163*^9, 3.920379373868133*^9}, {3.920379600869091*^9, 
  3.920379606855719*^9}, {3.982743333824553*^9, 3.982743349097619*^9}},
 CellLabel->"In[7]:=",
 CellID->1579233512,ExpressionUUID->"7ce8e40e-0e6f-402a-8430-4d7b7ea4a6f6"],

Cell[TextData[{
 "Compute the phase factors needed to fix the  ",
 StyleBox["SphericalLimit", "InlineCode"],
 " phase choice for each of the L=3 eigenfunctions."
}], "ExampleText",
 CellChangeTimes->{{3.9203845041048517`*^9, 3.9203846406669273`*^9}, {
   3.9203846795918407`*^9, 3.920384718306408*^9}, {3.920384755583188*^9, 
