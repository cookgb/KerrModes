Cell["\<\
Since we currently have no examples where the Spherical-Limit phase choice \
results in a \[Pi] phase discontinuity, we can artificially introduce such a \
change.\
\>", "ExampleText",
 CellChangeTimes->{{3.9203845041048517`*^9, 3.9203846406669273`*^9}, {
  3.9203846795918407`*^9, 3.920384718306408*^9}, {3.920384755583188*^9, 
  3.9203848057499857`*^9}, {3.920384860654337*^9, 3.920384911794429*^9}, {
  3.920384943346965*^9, 3.920384965914321*^9}, {3.9203851639593782`*^9, 
  3.920385176978166*^9}, {3.982743727278489*^9, 3.982743791204823*^9}},
 CellID->1009985524,ExpressionUUID->"c18eb7c7-e24b-4055-9984-05541b082895"],

Cell[BoxData[
 RowBox[{
  RowBox[{"phase", " ", "=", 
   RowBox[{"Join", "[", " ", 
    RowBox[{
     RowBox[{"Take", "[", 
      RowBox[{"phase", ",", "50"}], "]"}], ",", 
     RowBox[{"Exp", "[", 
      RowBox[{"\[ImaginaryI]", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"Arg", "[", 
          RowBox[{"Drop", "[", 
           RowBox[{"phase", ",", "50"}], "]"}], "]"}], "+", "\[Pi]"}], 
        ")"}]}], "]"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9827438061470213`*^9, 3.98274388867391*^9}, {
  3.9827439527771053`*^9, 3.982743961259063*^9}},
 CellLabel->"In[27]:=",
 CellID->96318700,ExpressionUUID->"a5ef40fd-a112-4a92-955a-815ac5f907a5"],

Cell["\<\
Plotting the phase factors, we see that there is a \[Pi] discontinuity in the \
phase angle near \[LeftBracketingBar]c\[RightBracketingBar]=2.45.\
\>", "ExampleText",
 CellChangeTimes->{{3.9203845041048517`*^9, 3.9203846406669273`*^9}, {
  3.9203846795918407`*^9, 3.920384718306408*^9}, {3.920384755583188*^9, 
  3.9203848057499857`*^9}, {3.920384860654337*^9, 3.920384911794429*^9}, {
  3.982744487649646*^9, 3.982744501622486*^9}},
 CellID->785748361,ExpressionUUID->"8bd5bf29-e35d-49a7-8823-dbeba9b7deeb"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ListLinePlot", "[", 
  RowBox[{"Transpose", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Table", "[", 
      RowBox[{"c", ",", 
       RowBox[{"{", 
        RowBox[{"c", ",", "0.0", ",", "5.0", ",", "0.05"}], "}"}]}], "]"}], ",", 
     RowBox[{"Arg", "[", "phase", "]"}]}], "}"}], "]"}], "]"}]], "Input",
 CellChangeTimes->{{3.920377595451429*^9, 3.920377635995017*^9}, {
  3.920377805478149*^9, 3.920377810447082*^9}, {3.920377860968532*^9, 
  3.920377862475999*^9}, {3.920379403345134*^9, 3.9203794048230133`*^9}, {
