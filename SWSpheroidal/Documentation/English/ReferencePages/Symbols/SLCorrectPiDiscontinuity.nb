Cell[TextData[{
 "We can again look for and correct any discontinuities.  Doing so, we find \
that most of the phase changes between adjacent points are small, with an \
average value similar to the standard deviation.  But, at the 50th element of \
the list, there is a \[Pi]  phase change that will be removed.  In this plot, \
any values near zero indicate a \[Pi] phase change.  The message : ",
 Cell[BoxData[
  RowBox[{" ", 
   RowBox[{"Flip", " ", 
    RowBox[{"index", " ", ":", " ", "#"}]}]}]], "InlineFormula",
  FormatType->StandardForm,ExpressionUUID->
  "056801e4-6adb-4320-832a-41d693a9eaa7"],
 " indicates that a \[Pi] discontinuity occurs after index # and that this \
discontinuity has been removed in the returned list of phase factors."
}], "ExampleText",
 CellChangeTimes->{{3.9203845041048517`*^9, 3.9203846406669273`*^9}, {
  3.9203846795918407`*^9, 3.920384718306408*^9}, {3.920384755583188*^9, 
  3.9203848057499857`*^9}, {3.920384860654337*^9, 3.920384911794429*^9}, {
  3.920384943346965*^9, 3.920384965914321*^9}, {3.9203851639593782`*^9, 
  3.9203852102345867`*^9}, {3.9203853097464933`*^9, 3.9203854785264587`*^9}, {
  3.920385564164176*^9, 3.92038559825028*^9}, {3.920732500663156*^9, 
  3.920732503658801*^9}, {3.920964929311368*^9, 3.9209649308626413`*^9}, {
  3.982744088812544*^9, 3.982744105282146*^9}, {3.982744539107225*^9, 
  3.982744565343234*^9}, {3.982744608318714*^9, 3.9827446162153*^9}, {
  3.982744646613579*^9, 3.982744753017104*^9}},
 CellID->200861944,ExpressionUUID->"70134feb-58bd-4a0f-8870-879c09f8196e"],

