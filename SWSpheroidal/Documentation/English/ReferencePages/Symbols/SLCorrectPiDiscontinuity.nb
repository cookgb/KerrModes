 CellID->1089467391,ExpressionUUID->"2c3bbdcc-5512-45a1-8c64-ea78c682bb88"],

Cell[BoxData[
 RowBox[{
  RowBox[{"phase", " ", "=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"SWSFfixphase", "[", 
      RowBox[{"0", ",", 
       RowBox[{"-", "2"}], ",", "3", ",", 
       RowBox[{"data", "[", 
        RowBox[{"[", 
         RowBox[{"i", ",", "2", ",", "4"}], "]"}], "]"}]}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", 
       RowBox[{"Length", "[", "data", "]"}]}], "}"}]}], "]"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.9203772440577383`*^9, 3.920377286987194*^9}, {
   3.920377338465763*^9, 3.9203773531350927`*^9}, {3.920377447911161*^9, 
