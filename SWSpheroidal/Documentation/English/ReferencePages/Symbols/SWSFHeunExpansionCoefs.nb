Cell[TextData[{
 "Compute the first 25 spin-weighted spheroidal eigensolutions for m=1, s=2, \
and  ",
 Cell[BoxData[
  RowBox[{"c", "=", 
   FractionBox["1", "2"]}]],ExpressionUUID->
  "b1999e4c-18b9-4cfe-86c6-7bef9ad32423"],
 "- \[ImaginaryI] using the spectral method."
}], "ExampleText",
 CellChangeTimes->{{3.879511861627557*^9, 3.879511938566236*^9}, 
   3.879512034799692*^9, {3.879512109478351*^9, 3.879512111885686*^9}, {
   3.879513835126093*^9, 3.8795138375330963`*^9}, {3.9816401118062973`*^9, 
   3.981640127533518*^9}},
 CellID->1497641714,ExpressionUUID->"fac1a172-50a6-4dfd-b5e5-7518b40a0518"],

Cell[BoxData[
 RowBox[{
  RowBox[{"data", "=", 
   RowBox[{"SpinWeightedSpheroidal", "[", 
    RowBox[{"1", ",", "2", ",", 
     RowBox[{"0.5", "-", "\[ImaginaryI]"}], ",", "25"}], "]"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.981640294350387*^9, 3.981640294619711*^9}},
 CellLabel->"In[4]:=",
 CellID->1233131794,ExpressionUUID->"348685c1-c429-47c8-ae1f-4e89a26cf3ae"],

Cell["\<\
Use the conformal Heun approach to recompute the first 5 eigenvalues:\
\>", "ExampleText",
 CellChangeTimes->{{3.879511861627557*^9, 3.879511938566236*^9}, 
   3.879512034799692*^9, {3.879512109478351*^9, 3.879512111885686*^9}, {
