Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"-", "0.16298016767644985`"}], "+", 
    RowBox[{"1.8883505418277398`", " ", "\[ImaginaryI]"}]}], ",", 
   RowBox[{"5.911737245485726`", "\[VeryThinSpace]", "+", 
    RowBox[{"1.0211746296557562`", " ", "\[ImaginaryI]"}]}], ",", 
   RowBox[{"14.052056769618883`", "\[VeryThinSpace]", "+", 
