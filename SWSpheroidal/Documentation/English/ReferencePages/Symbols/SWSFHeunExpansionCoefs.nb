Cell[TextData[{
 "Note that without specifying values for ",
 ButtonBox["WorkingPrecision",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/WorkingPrecision"],
 " and ",
 ButtonBox["AccuracyGoal",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/AccuracyGoal"],
 ", NIntegrate may complain when the inner-product integrations evaluate to \
near zero.  This warning cannot be turned off.  Never-the-less, if we \
computed the phase corrected expansion coefficients from the spectral method, \
the results are essentially identical to ",
 ButtonBox["MachinePrecision",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/MachinePrecision"],
 "."
}], "ExampleText",
