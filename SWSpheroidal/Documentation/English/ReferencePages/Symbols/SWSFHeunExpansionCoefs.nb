Notebook[{

Cell[CellGroupData[{
Cell["SWSFHeunExpansionCoefs", "ObjectName",
 CellID->1908683687,ExpressionUUID->"d593bc68-6ef6-4ff7-a1ca-75d69dae69de"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"7d1848f1-25fe-4751-bc44-ba2c460586d7"],
 Cell[BoxData[
  RowBox[{"SWSFHeunExpansionCoefs", "[", 
   RowBox[{
    StyleBox["s", "TI"], ",", 
    StyleBox["m", "TI"], ",", 
    StyleBox["l", "TI"], ",", 
    StyleBox["c", "TI"], ",", 
    StyleBox["Alm",
     FontSlant->"Italic"]}], "]"}]], "InlineFormula",ExpressionUUID->
  "2c154830-d41b-49d6-9f97-ae751180c837"],
 "\[LineSeparator]returns a list of complex expansion coefficients necessary \
to represent the spin-weighted spheroidal function with spin-weight ",
 Cell[BoxData[
  StyleBox["s", "TI"]], "InlineFormula",ExpressionUUID->
  "e8e1f38d-44a1-44a3-a046-968316678ba6"],
 ", azimuthal index ",
 Cell[BoxData[
  StyleBox["m", "TI"]], "InlineFormula",ExpressionUUID->
  "79c9c5a9-b0d8-462b-a57f-7da3a067c68b"],
 ",  harmonic index ",
 Cell[BoxData[
  StyleBox["l", "TI"]], "InlineFormula",ExpressionUUID->
  "920c4fdc-5f25-4ff5-9b00-cff3b54acc96"],
 ", oblateness parameter ",
 Cell[BoxData[
  StyleBox["c", "TI"]], "InlineFormula",ExpressionUUID->
  "1abfa840-ffff-4e9e-8acd-d125990c6b63"],
 ", and eigenvalue  ",
 Cell[BoxData[
  StyleBox["Alm", "TI"]], "InlineFormula",ExpressionUUID->
  "620ea979-d708-4842-86a5-923f1ca357de"],
 " as a linear combination of spin-weighted spherical functions."
}], "Usage",
 CellChangeTimes->{{3.981564648006109*^9, 3.9815646722254887`*^9}, {
  3.98156475249666*^9, 3.9815647566443157`*^9}},
 CellID->473429761,ExpressionUUID->"0fdbd03d-ffc2-47fe-97fe-3f1f133d6714"],

Cell[TextData[{
 Cell[BoxData[
  ButtonBox["SWSFHeunExpansionCoefs",
   BaseStyle->"Link",
   ButtonData->"paclet:SWSpheroidal/ref/SWSFHeunExpansionCoefs"]], 
  "InlineFormula",ExpressionUUID->"6bceb3af-df78-4fde-869b-ae6acbbd10a1"],
 " first computes the normalization and phase factors using ",
 Cell[BoxData[
  ButtonBox["SWSFHeunNorms",
   BaseStyle->"Link",
   ButtonData->"paclet:SWSpheroidal/ref/SWSFHeunNorms"]], "InlineFormula",
  ExpressionUUID->"b59b5fbb-3995-4a63-89c9-38c5628fa969"],
 " and ",
 Cell[BoxData[
  ButtonBox["SWSFHeunPhases",
   BaseStyle->"Link",
   ButtonData->"paclet:SWSpheroidal/ref/SWSFHeunPhases"]], "InlineFormula",
  ExpressionUUID->"33f9d4d5-f9bd-42d2-83b6-7d1840b7f074"],
 ", then computed the properly normalized and phase-fixed expansion \
coefficients needed to represent the spin-weighted spheroidal function as a \
linear combination of spin-weighted spherical functions."
}], "Notes",
 CellChangeTimes->{{3.981565168127831*^9, 3.981565318197858*^9}, {
  3.981565368203236*^9, 3.981565368204121*^9}, {3.9817301806846848`*^9, 
  3.981730180685444*^9}},
 CellID->73929055,ExpressionUUID->"4d48ad3d-eed8-4533-82ea-288a2c18683c"],

Cell[TextData[{
 "The returned expansion coefficients correspond to the spectral coefficients \
returned by ",
 Cell[BoxData[
  ButtonBox["AngularSpectralRoot",
   BaseStyle->"Link",
   ButtonData->"paclet:SWSpheroidal/ref/AngularSpectralRoot"]], 
  "InlineFormula",ExpressionUUID->"e6113c2f-b826-4e3a-8f92-dec4f9a2f12d"],
 " (and related functions) and can be used in ",
 Cell[BoxData[
  ButtonBox["SWSFvalues",
   BaseStyle->"Link",
   ButtonData->"paclet:SWSpheroidal/ref/SWSFvalues"]], "InlineFormula",
  ExpressionUUID->"42721cea-d6c5-4f6d-8dde-b57f93434e06"],
 " to evaluate the spin-weighted spheroidal function."
}], "Notes",
 CellChangeTimes->{{3.981565168127831*^9, 3.981565318197858*^9}, {
  3.981565466951466*^9, 3.9815655943382607`*^9}},
 CellID->1313727678,ExpressionUUID->"eb623070-97c1-4198-9523-6eda382f44b1"],

Cell[TextData[{
 Cell[BoxData[
  ButtonBox["SWSFHeunExpansionCoefs",
   BaseStyle->"Link",
   ButtonData->"paclet:SWSpheroidal/ref/SWSFHeunExpansionCoefs"]], 
  "InlineFormula",ExpressionUUID->"629c2fb9-b451-4b90-8a4f-ba7283d5a418"],
 " will compute enough expansion coefficients so that the sum of the square \
magnitudes of all coefficients is within ",
 StyleBox["CoefDelta", "InlineCode"],
 " of 1 and the magnitudes of the last two coefficients are smaller than ",
 StyleBox["CoefDelta", "InlineCode"],
 "."
}], "Notes",
 CellChangeTimes->{{3.981565168127831*^9, 3.981565318197858*^9}, {
  3.981565368203236*^9, 3.981565368204121*^9}, {3.981730186440436*^9, 
  3.981730335347097*^9}},
 CellID->1076265872,ExpressionUUID->"7cc6feb3-ee14-4c9c-a428-cd4a8183fed8"],

