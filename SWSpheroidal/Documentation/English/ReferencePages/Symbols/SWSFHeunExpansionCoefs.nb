   3.981640127533518*^9}, {3.98164018647022*^9, 3.98164022293968*^9}, {
   3.981641429280558*^9, 3.98164146687932*^9}},
 CellID->1631999759,ExpressionUUID->"89d1a6ac-c148-485e-abaf-f7b36e894236"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Alms", "=", 
  RowBox[{
   RowBox[{
    RowBox[{"SWSpheroidalWronskianRoot", "[", 
     RowBox[{"2", ",", "1", ",", 
      RowBox[{
       RowBox[{"1", "/", "2"}], "-", "\[ImaginaryI]"}], ",", "#"}], "]"}], 
    "&"}], "/@", 
   RowBox[{"Take", "[", 
    RowBox[{
     RowBox[{"data", "[", 
      RowBox[{"[", "1", "]"}], "]"}], ",", "5"}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.981640266494829*^9, 3.981640316378229*^9}, {
  3.981640358271346*^9, 3.9816403608160067`*^9}, {3.981640432886176*^9, 
