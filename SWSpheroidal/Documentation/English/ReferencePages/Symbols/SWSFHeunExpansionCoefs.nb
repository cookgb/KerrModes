Cell[BoxData[
 TemplateBox[{
  "NIntegrate", "ncvb", 
   "\"NIntegrate failed to converge to prescribed accuracy after \
\\!\\(\\*RowBox[{\\\"9\\\"}]\\) recursive bisections in \
\\!\\(\\*RowBox[{\\\"SWSpheroidal`Private`x\\\"}]\\) near \\!\\(\\*RowBox[{\\\
\"{\\\", \\\"SWSpheroidal`Private`x\\\", \\\"}\\\"}]\\) = \\!\\(\\*RowBox[{\\\
\"{\\\", RowBox[{\\\"-\\\", \
\\\"0.99999230143142520007055085336233890558332859654910862445831298828`65.\
