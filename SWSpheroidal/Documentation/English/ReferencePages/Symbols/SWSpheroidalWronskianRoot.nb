Cell[CellGroupData[{
Cell["SWSpheroidalWronskianRoot", "ObjectName",
 CellID->724265887,ExpressionUUID->"c09c7ebf-f3c9-4699-8963-ca6dc8e55f55"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"8b8c9da1-c81e-470d-a1ed-72c1085246ed"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["SWSpheroidalWronskianRoot",
    BaseStyle->"Link",
    ButtonData->"paclet:SWSpheroidal/ref/SWSpheroidalWronskianRoot"], "[", 
   RowBox[{
    StyleBox["s", "TI"], ",", 
    StyleBox["m", "TI"], ",", 
    StyleBox["c", "TI"], ",", 
    StyleBox["Alm",
     FontSlant->"Italic"]}], "]"}]], "InlineFormula",ExpressionUUID->
  "10b893f0-110a-4c1f-b87d-d952da61111c"],
 "\[LineSeparator]returns an eigenvalue near ",
 Cell[BoxData[
  StyleBox["Alm", "TI"]], "InlineFormula",ExpressionUUID->
  "e2b9dd08-006e-40c0-9a48-37b8a4ed521b"],
 " associated with a spin-weighted spheroidal function with spin-weight ",
 Cell[BoxData[
  StyleBox["s", "TI"]], "InlineFormula",ExpressionUUID->
  "eed781e9-f56c-449d-865d-509ce751445a"],
 ", azimuthal index ",
 Cell[BoxData[
  StyleBox["m", "TI"]], "InlineFormula",ExpressionUUID->
  "d876bc0f-dd9b-4840-aa21-40fce76adb2e"],
 ", and oblateness parameter ",
 Cell[BoxData[
  StyleBox["c", "TI"]], "InlineFormula",ExpressionUUID->
  "83d6469d-118c-4978-a518-b0d8cec44869"],
 "."
}], "Usage",
 CellChangeTimes->{{3.9811244616916857`*^9, 3.981124487059086*^9}, 
   3.981124528565189*^9, {3.981124589463773*^9, 3.981124706125023*^9}, {
   3.981124785236147*^9, 3.981124827701631*^9}, {3.981559931304484*^9, 
   3.9815599359399137`*^9}},
 CellID->2052179626,ExpressionUUID->"3b2f5c10-42e2-4337-8f44-bb74e8a92840"],

Cell[TextData[{
 Cell[BoxData[
  ButtonBox["SWSpheroidalWronskianRoot",
   BaseStyle->"Link",
   ButtonData->"paclet:SWSpheroidal/ref/SWSpheroidalWronskianRoot"]], 
  "InlineFormula",
  FormatType->StandardForm,ExpressionUUID->
  "c5909675-8d3f-4e6e-aed3-b46953e7fa45"],
 " uses ",
 Cell[BoxData[
  ButtonBox["FindRoot",
   BaseStyle->"Link",
   ButtonData->"paclet:ref/FindRoot"]], "InlineFormula",
  FormatType->StandardForm,ExpressionUUID->
  "67a6864c-2555-4e36-a3e1-dd9c538e0702"],
 " to find a root of the spin-weighted spheroidal function Wronskian."
}], "Notes",
 CellChangeTimes->{{3.981125072594865*^9, 3.981125087578423*^9}, {
  3.981125129633469*^9, 3.981125174418499*^9}},
 CellID->1000479291,ExpressionUUID->"a88a7c6b-8ce8-428c-ba44-900134c01d17"],

Cell[TextData[{
 "The spin-weighted spheroidal function Wronskian is constructed from two \
solutions of the angular Teukolsky equation, one regular at ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "=", "1"}], TraditionalForm]], "InlineMath",ExpressionUUID->
  "ae7fdfe0-9800-4ae2-bd15-78ba7f7acf1d"],
 " and the other at ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "=", 
    RowBox[{"-", "1"}]}], TraditionalForm]], "InlineMath",ExpressionUUID->
  "a8f3f05c-3b73-4834-afad-e78b27642c4c"],
 " for any value of the angular separation constant ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[InvisiblePrefixScriptBase]", "s"], 
    SubscriptBox["A", 
     StyleBox[
      RowBox[{"\[ScriptL]", 
       StyleBox["m", "TI"]}]]]}], TraditionalForm]], "InlineMath",
  ExpressionUUID->"03cb054f-bf84-410d-b70e-430fdf8207f4"],
 " .  At roots of the Wronskian, the two solutions are linearly dependent and \
represent regular solutions of the angular Teukolsky equation."
}], "Notes",
 CellChangeTimes->{{3.98112522413225*^9, 3.98112545041848*^9}, {
  3.9811255048218*^9, 3.9811255606894503`*^9}},
 CellID->136225217,ExpressionUUID->"1f6ed5a9-c926-4328-a651-ebdcb2d180cc"],

