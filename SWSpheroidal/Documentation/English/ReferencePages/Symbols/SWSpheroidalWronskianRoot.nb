  ButtonBox["FindRoot",
   BaseStyle->"Link",
   ButtonData->"paclet:ref/FindRoot"]], "InlineFormula",
  FormatType->StandardForm,ExpressionUUID->
  "c9790f8f-6318-4b1c-bc0a-17aad823ccb1"],
 " are available.  In addition, the following option can also be given:"
}], "Notes",
 CellChangeTimes->{{3.981126188017494*^9, 3.981126270007784*^9}},
 CellID->1505437583,ExpressionUUID->"c7366202-1973-4eeb-8094-bf799ac73868"],

