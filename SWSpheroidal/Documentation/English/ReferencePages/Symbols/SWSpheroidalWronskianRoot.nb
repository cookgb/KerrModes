 RowBox[{
  RowBox[{"data", "=", 
   RowBox[{"SpinWeightedSpheroidal", "[", 
    RowBox[{"1", ",", "2", ",", 
     RowBox[{"0.5", "-", "\[ImaginaryI]"}], ",", "25"}], "]"}]}], 
  ";"}]], "Input",
