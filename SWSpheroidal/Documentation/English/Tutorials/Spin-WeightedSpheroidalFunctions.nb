Cell[CellGroupData[{

Cell["Regular solutions at both regular singular points", "Subsection",
 CellChangeTimes->{
  3.981619862261105*^9, {3.9816199937998667`*^9, 3.981620008480575*^9}, {
   3.981621279624362*^9, 3.9816212796244097`*^9}, {3.981626788306278*^9, 
   3.981626792895652*^9}},
 CellID->1430096457,ExpressionUUID->"987eba84-db80-427c-86b1-6cb932f95c43"],

Cell[TextData[{
 "The solutions which are regular at only one of the singular points are \
valid for any value of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[InvisiblePrefixScriptBase]", "s"], 
     SubscriptBox["A", 
      RowBox[{"\[ScriptL]", ",", "m"}]]}], 
    RowBox[{"(", "c", ")"}]}], TraditionalForm]], "InlineMath",ExpressionUUID->
  "e37a5c96-f943-48c8-9a2a-046371d980d3"],
 ". The spin-weighted spheroidal functions must be regular at both singular \
points, and this will only happen as specific values of  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[InvisiblePrefixScriptBase]", "s"], 
     SubscriptBox["A", 
      RowBox[{"\[ScriptL]", ",", "m"}]]}], 
    RowBox[{"(", "c", ")"}]}], TraditionalForm]], "InlineMath",ExpressionUUID->
  "f461531b-6677-45a9-a75b-196b69d2568d"],
 ".  This constitutes an eigenvalue problem for the the eigenfunctions ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[InvisiblePrefixScriptBase]", "s"], 
     SubscriptBox["S", 
      RowBox[{"\[ScriptL]", ",", "m"}]]}], 
    RowBox[{"(", 
     RowBox[{"x", ",", "c"}], ")"}]}], TraditionalForm]], "InlineMath",
  ExpressionUUID->"bc89ab45-ca4e-489f-8d90-48eb690885cf"],
 "  and their associated eigenvalues ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[InvisiblePrefixScriptBase]", "s"], 
     SubscriptBox["A", 
      RowBox[{"\[ScriptL]", ",", "m"}]]}], 
    RowBox[{"(", "c", ")"}]}], TraditionalForm]], "InlineMath",ExpressionUUID->
  "ebd67d77-fbb2-4ec1-8131-db3b3869df1a"],
 ", with the different eigensolutions indexed by the harmonic index ",
 Cell[BoxData[
  FormBox["\[ScriptL]", TraditionalForm]], "InlineMath",ExpressionUUID->
  "096bb7e3-d8d1-44f9-bf9f-7ec3db77f2f6"],
 ".  Solutions of the eigenvalue problem are obtained by finding zeros of the \
Wronskian constructed from a pair of local solutions, one regular at each \
singular point.  The Wronskian will vanish whenever the two solutions used to \
construct the Wronskian are linearly dependent."
}], "Text",
 CellChangeTimes->{{3.9815663928117456`*^9, 3.9815666132900543`*^9}, {
  3.981566997075536*^9, 3.981567220322131*^9}, {3.981619607694396*^9, 
  3.9816198465318108`*^9}, {3.981621040188684*^9, 3.9816211309341707`*^9}, {
  3.981621183964094*^9, 3.98162125040646*^9}, {3.9816217642212887`*^9, 
  3.981621804225772*^9}, {3.981626825881598*^9, 3.981627190813201*^9}, {
  3.981627238804851*^9, 3.9816272743319473`*^9}, {3.981627312447604*^9, 
  3.981627375447927*^9}},
 CellID->393300395,ExpressionUUID->"9bd55cf7-0c4b-49b0-a977-f0ecfb66a7ba"],

Cell[TextData[{
 "Given an eigenvalue ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[InvisiblePrefixScriptBase]", "s"], 
     SubscriptBox["A", 
      RowBox[{"\[ScriptL]", ",", "m"}]]}], 
    RowBox[{"(", "c", ")"}]}], TraditionalForm]], "InlineMath",ExpressionUUID->
  "3dd0805e-0ce6-4369-a73a-0ce4e52ff3a3"],
 ", we can evaluate the associated eigenfunction ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[InvisiblePrefixScriptBase]", "s"], 
     SubscriptBox["S", 
      RowBox[{"\[ScriptL]", ",", "m"}]]}], 
    RowBox[{"(", 
     RowBox[{"x", ",", "c"}], ")"}]}], TraditionalForm]], "InlineMath",
  ExpressionUUID->"19047f50-539b-4a97-b2e5-23217fd9a70b"],
 " using the any of the 16 versions described above.  However, they do not \
all yield equally accurate results.  Optimal solutions exist based on three \
criteria:  ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{"m", "+", "s"}]},
    "Sign"], TraditionalForm]], "InlineMath",ExpressionUUID->
  "f182f507-d7ef-47e7-b105-05131e197402"],
 ", ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{"m", "-", "s"}]},
    "Sign"], TraditionalForm]], "InlineMath",ExpressionUUID->
  "7541fda4-195f-4579-95b4-d7f503bae77d"],
 ", and ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{"Re", "(", "c", ")"}]},
    "Sign"], TraditionalForm]], "InlineMath",ExpressionUUID->
  "8b46bc44-824b-4a3f-beb5-f1c3a796f747"],
 "."
}], "Text",
 CellChangeTimes->{{3.9815663928117456`*^9, 3.9815666132900543`*^9}, {
  3.981566997075536*^9, 3.981567220322131*^9}, {3.981619607694396*^9, 
  3.9816198465318108`*^9}, {3.981621040188684*^9, 3.9816211309341707`*^9}, {
  3.981621183964094*^9, 3.98162125040646*^9}, {3.9816217642212887`*^9, 
  3.981621804225772*^9}, {3.981626825881598*^9, 3.981627190813201*^9}, {
  3.981627238804851*^9, 3.9816272743319473`*^9}, {3.981627312447604*^9, 
  3.981627375447927*^9}, {3.981627457626051*^9, 3.98162754208346*^9}, {
  3.981627572954205*^9, 3.981627743975319*^9}},
 CellID->1227532417,ExpressionUUID->"b269b39a-4871-45d5-a7ca-b3017503c02f"]
}, Open  ]]
}, Open  ]],

