Notebook[{

Cell[CellGroupData[{
Cell["Spin-Weighted Spheroidal Functions", "Title",
 CellChangeTimes->{3.879775788910966*^9, 3.882439929107978*^9},
 CellID->1380494707,ExpressionUUID->"57650713-172b-4ab7-951d-3c34d4a8862c"],

Cell[CellGroupData[{

Cell["Overview", "Section",
 CellChangeTimes->{{3.879776530572141*^9, 3.8797765317894917`*^9}},
 CellID->1805093217,ExpressionUUID->"c0f8787b-797a-43b6-9745-76e5e22b1a5d"],

Cell[TextData[{
 "Spin-weighted spheroidal harmonics ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[InvisiblePrefixScriptBase]", "s"], 
     SubscriptBox["S", 
      RowBox[{"\[ScriptL]", ",", "m"}]]}], 
    RowBox[{"(", 
     RowBox[{"\[Theta]", ",", "\[Phi]", ",", "c"}], ")"}]}], 
   TraditionalForm]], "InlineMath",ExpressionUUID->
  "81832ea1-19e6-413d-b72a-24a65d387291"],
 " are generalizations of both the spin-weighted spherical harmonics and the \
scalar spheroidal harmonics.  Here, ",
 Cell[BoxData[
  FormBox["s", TraditionalForm]], "InlineMath",ExpressionUUID->
  "6ababcf7-3305-4a0f-90d9-43fce55453db"],
 " denotes the spin weight of the function, ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]], "InlineMath",ExpressionUUID->
  "edd633fb-37f1-447c-84ee-6d996c853a5f"],
 " is the azimuthal index, both of which take on either integer or \
half-integer values.   ",
 Cell[BoxData[
  FormBox["c", TraditionalForm]], "InlineMath",ExpressionUUID->
  "e730d670-d649-4447-bd56-4a7f5e5d47b5"],
 " is a complex number often called the oblateness parameter and the final \
index, ",
 Cell[BoxData[
  FormBox["\[ScriptL]", TraditionalForm]], "InlineMath",ExpressionUUID->
  "365ef8f6-e1b9-4c18-a031-15d59d5be62f"],
 ", is the harmonic index which is usually chosen to take on consecutive \
values ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptL]", "\[GreaterEqual]", 
    RowBox[{"max", "(", 
     RowBox[{
      RowBox[{"\[LeftBracketingBar]", "s", "\[RightBracketingBar]"}], ",", 
      RowBox[{"\[LeftBracketingBar]", "m", "\[RightBracketingBar]"}]}], 
     ")"}]}], TraditionalForm]], "InlineMath",ExpressionUUID->
  "a030999d-0238-4d09-ad01-4216de24c49f"],
 " which differ by an integer.  In terms of the spin-weighted spheroidal \
functions ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[InvisiblePrefixScriptBase]", "s"], 
     SubscriptBox["S", 
      RowBox[{"\[ScriptL]", ",", "m"}]]}], 
    RowBox[{"(", 
     RowBox[{"x", ",", "c"}], ")"}]}], TraditionalForm]], "InlineMath",
  ExpressionUUID->"26327e5e-8c9a-4b4c-8a39-602f834967e0"],
 ", the harmonics are written as"
}], "Text",
 CellChangeTimes->{{3.879776727388145*^9, 3.879776729599846*^9}, {
   3.879776783890761*^9, 3.879776843859508*^9}, {3.87977693785276*^9, 
   3.879777230298813*^9}, 3.879777812947028*^9, {3.8797779665450773`*^9, 
   3.879777975956613*^9}, {3.879778143877875*^9, 3.879778206078485*^9}, {
   3.879778242687229*^9, 3.879778307237006*^9}, {3.879778398601063*^9, 
   3.879778450808243*^9}, {3.879778500524648*^9, 3.879778538590988*^9}, {
   3.879778624036986*^9, 3.8797787643074512`*^9}, {3.8797831364376383`*^9, 
   3.87978316291186*^9}, {3.882465827775261*^9, 3.882465850422801*^9}, {
   3.88246593715726*^9, 3.882466056919921*^9}, {3.9363544184608912`*^9, 
   3.936354419877136*^9}},
 CellID->946771371,ExpressionUUID->"69a0de37-bd41-432f-b734-f6759faa6231"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      SubscriptBox["\[InvisiblePrefixScriptBase]", "s"], 
      SubscriptBox["S", 
       RowBox[{"\[ScriptL]", ",", "m"}]]}], 
     RowBox[{"(", 
      RowBox[{"\[Theta]", ",", "\[Phi]", ",", "c"}], ")"}]}], "\[LongEqual]", 
    
    RowBox[{
     FractionBox["1", 
      SqrtBox[
       RowBox[{"2", "\[Pi]"}]]], 
     RowBox[{
      SubscriptBox["\[InvisiblePrefixScriptBase]", "s"], 
      SubscriptBox["S", 
       RowBox[{"\[ScriptL]", ",", "m"}]]}], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"cos", "(", "\[Theta]", ")"}], ",", "c"}], ")"}], 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"\[ImaginaryI]", " ", "m", " ", "\[Phi]"}]]}]}], 
   TraditionalForm]], "InlineMath",ExpressionUUID->
  "a189231c-903f-40cc-9cd9-a4eaf35c3430"],
 ","
}], "DisplayMath",
 CellChangeTimes->{{3.882520808294332*^9, 3.882520933620928*^9}, {
  3.915898062091734*^9, 3.915898062091777*^9}, {3.9159767950127907`*^9, 
  3.915976795012829*^9}},
 CellID->2042889307,ExpressionUUID->"0f5010a8-1bbd-4caf-a4e2-e9ef9de42be6"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "\[LongEqual]", 
    RowBox[{"cos", "(", "\[Theta]", ")"}]}], TraditionalForm]], "InlineMath",
  ExpressionUUID->"22230dcf-eb7b-4d8b-9f48-36287c3d77ed"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[InvisiblePrefixScriptBase]", "s"], 
     SubscriptBox["S", 
      RowBox[{"\[ScriptL]", ",", "m"}]]}], 
    RowBox[{"(", 
     RowBox[{"x", ",", "c"}], ")"}]}], TraditionalForm]], "InlineMath",
  ExpressionUUID->"f8567278-c464-4bce-b867-31b63d5e52ee"],
 " satisfies the angular Teukolsky equation"
}], "Text",
 CellChangeTimes->{{3.879777606957023*^9, 3.879777648271242*^9}, {
   3.879778784154133*^9, 3.879778790380474*^9}, {3.8797790225110693`*^9, 
   3.879779078037679*^9}, 3.882465868338694*^9, {3.882466097915711*^9, 
   3.8824661012864437`*^9}, {3.882520845918427*^9, 3.882520845918514*^9}},
 CellID->2082974710,ExpressionUUID->"b42a5a33-c366-48ff-864a-e15eaa4de0ec"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{
     SubscriptBox["\[PartialD]", "x"], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", 
         SuperscriptBox["x", "2"]}], ")"}], 
       RowBox[{
        SubscriptBox["\[PartialD]", "x"], 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           SubscriptBox["\[InvisiblePrefixScriptBase]", "s"], 
           SubscriptBox["S", 
            RowBox[{"\[ScriptL]", ",", "m"}]]}], 
          RowBox[{"(", 
           RowBox[{"x", ",", "c"}], ")"}]}], ")"}]}]}], ")"}]}], "+", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"c", " ", "x"}], ")"}], "2"], "+", 
       RowBox[{
        RowBox[{"-", "2"}], " ", "c", " ", "s", " ", "x"}], "+", "s", "+", 
       RowBox[{
        RowBox[{
         SubscriptBox["\[InvisiblePrefixScriptBase]", "s"], 
         SubscriptBox["A", 
          RowBox[{"\[ScriptL]", ",", "m"}]]}], 
        RowBox[{"(", "c", ")"}]}], "-", 
       FractionBox[
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"m", "+", 
           RowBox[{"s", " ", "x"}]}], ")"}], "2"], 
        RowBox[{"1", "-", 
         SuperscriptBox["x", "2"]}]]}], ")"}], 
     RowBox[{
      SubscriptBox["\[InvisiblePrefixScriptBase]", "s"], 
      SubscriptBox["S", 
       RowBox[{"\[ScriptL]", ",", "m"}]]}], 
     RowBox[{"(", 
      RowBox[{"x", ",", "c"}], ")"}]}]}], "\[LongEqual]", "0"}], 
  TraditionalForm]], \
"InlineMath",ExpressionUUID->"a049576d-38d4-43ff-8213-954e0f792333"]], \
"DisplayMath",
 CellChangeTimes->{{3.882465229270844*^9, 3.882465520500508*^9}, {
  3.936354445130335*^9, 3.936354445130466*^9}},
 CellID->2514541,ExpressionUUID->"fdb59234-6cce-4c1f-b1ec-1a91b625742b"],

Cell[TextData[{
 "In addition to the spin-weighted spheroidal functions ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[InvisiblePrefixScriptBase]", "s"], 
     SubscriptBox["S", 
      RowBox[{"\[ScriptL]", ",", "m"}]]}], 
    RowBox[{"(", 
     RowBox[{"x", ",", "c"}], ")"}]}], TraditionalForm]], "InlineMath",
  ExpressionUUID->"87f09e90-f478-474d-aaca-df5a04ec01c5"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[InvisiblePrefixScriptBase]", "s"], 
     SubscriptBox["A", 
      RowBox[{"\[ScriptL]", ",", "m"}]]}], 
    RowBox[{"(", "c", ")"}]}], TraditionalForm]], "InlineMath",ExpressionUUID->
  "aba4eb67-200f-47a4-af71-426a17974f04"],
 " is its associated eigenvalue often referred to as the angular separation \
constant.  For fixed values of ",
 Cell[BoxData[
  FormBox["s", TraditionalForm]], "InlineMath",ExpressionUUID->
  "0d1202fa-aab2-4d2c-b724-9ee8bf4e9b63"],
 ", ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]], "InlineMath",ExpressionUUID->
  "72ec77c4-bf06-48b0-af1f-f493b7b73681"],
 ", and ",
 Cell[BoxData[
  FormBox["c", TraditionalForm]], "InlineMath",ExpressionUUID->
  "0951f6d1-e2a9-4e92-b518-ad55762ff31f"],
 ", the angular Teukolsky equation has an infinite number of eigensolutions \
labeled by the harmonic index ",
 Cell[BoxData[
  FormBox["\[ScriptL]", TraditionalForm]], "InlineMath",ExpressionUUID->
  "288be571-68e4-4676-9a35-42a162a541ef"],
 "."
}], "Text",
 CellChangeTimes->{{3.879777791205222*^9, 3.879777933520883*^9}, {
   3.8797780051453743`*^9, 3.879778093491424*^9}, {3.879778253917128*^9, 
   3.879778259254789*^9}, {3.879778994236034*^9, 3.879779006078246*^9}, {
   3.879779155253817*^9, 3.879779300218127*^9}, {3.879782898179716*^9, 
   3.879782907389093*^9}, {3.882465879462184*^9, 3.882465897002859*^9}, {
   3.882466117812252*^9, 3.882466143609552*^9}, 3.936354461120241*^9, 
   3.936363212308391*^9},
 CellID->1638509359,ExpressionUUID->"d4d12106-9a62-4c79-9b88-488c7756081d"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Solving the Eigensystem", "Section",
 CellChangeTimes->{{3.879776557714272*^9, 3.8797765654156713`*^9}},
 CellID->1680091774,ExpressionUUID->"6bd73dbe-49c8-4940-afed-8751af918916"],

Cell[TextData[{
 "The spin-weighted spheroidal eigensystem can be solved numerically by \
converting it into a discrete eigensystem by means of a spectral \
representation.  The details of the implementation can be found in ",
 ButtonBox["Cook and Zalutskiy (2014)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1103/PhysRevD.90.124021"], None}],
 ".  The spectral representation is"
}], "Text",
 CellChangeTimes->{{3.879775988986349*^9, 3.879776004995555*^9}, {
  3.879776165193665*^9, 3.879776177647758*^9}, {3.87977936703969*^9, 
  3.879779418445298*^9}, {3.8797794709398923`*^9, 3.879779483070236*^9}, {
  3.882521520780982*^9, 3.88252152747558*^9}, {3.88252155943572*^9, 
  3.882521560155501*^9}, {3.882524068730397*^9, 3.882524148091366*^9}},
 CellID->561218361,ExpressionUUID->"5d6ff70e-f14b-4890-91df-310a1bc5cd65"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      SubscriptBox["\[InvisiblePrefixScriptBase]", "s"], 
      SubscriptBox["S", 
       RowBox[{"\[ScriptL]", ",", "m"}]]}], 
     RowBox[{"(", 
      RowBox[{"x", ",", "c"}], ")"}]}], "\[LongEqual]", 
    RowBox[{
     UnderoverscriptBox["\[Sum]", 
      RowBox[{
       OverscriptBox["\[ScriptL]", "^"], "=", 
       RowBox[{"max", "(", 
        RowBox[{
         RowBox[{"\[LeftBracketingBar]", "s", "\[RightBracketingBar]"}], ",", 
         
         RowBox[{"\[LeftBracketingBar]", "m", "\[RightBracketingBar]"}]}], 
        ")"}]}], "\[Infinity]"], 
     RowBox[{
      RowBox[{
       SubscriptBox["\[InvisiblePrefixScriptBase]", "s"], 
       SubscriptBox["\[ScriptCapitalA]", 
        RowBox[{
         OverscriptBox["\[ScriptL]", "^"], ",", "\[ScriptL]", ",", "m"}]]}], 
      RowBox[{"(", "c", ")"}], 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"-", "1"}], ")"}], 
       RowBox[{"s", "+", "\[Eta]"}]], 
      SqrtBox[
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"2", 
           OverscriptBox["\[ScriptL]", "^"]}], "+", "1"}], ")"}], "/", "2"}]], 
      RowBox[{
       SubsuperscriptBox["d", 
        RowBox[{"m", ",", 
         RowBox[{"-", "s"}]}], 
        OverscriptBox["\[ScriptL]", "^"]], "(", 
       RowBox[{
        SuperscriptBox["cos", 
         RowBox[{"-", "1"}]], "(", "x", ")"}], ")"}]}]}]}], TraditionalForm]],
   "InlineMath",ExpressionUUID->"376bac0a-9862-41b8-8be0-1c023370a576"],
 "."
}], "DisplayMath",
 CellChangeTimes->{{3.8825213927324147`*^9, 3.882521604037859*^9}, {
   3.882522061407856*^9, 3.882522061408014*^9}, 3.88252415551791*^9, {
   3.915898068475814*^9, 3.915898072255459*^9}, {3.916133287460036*^9, 
   3.916133323430292*^9}, {3.9164116214139752`*^9, 3.916411624781077*^9}, {
   3.916412001398948*^9, 3.9164120072262692`*^9}},
 CellID->1679662951,ExpressionUUID->"c89adca1-0d02-435e-9094-72c896671c21"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[InvisiblePrefixScriptBase]", "s"], 
     SubscriptBox["\[ScriptCapitalA]", 
      RowBox[{
       OverscriptBox["\[ScriptL]", "^"], ",", "\[ScriptL]", ",", "m"}]]}], 
    RowBox[{"(", "c", ")"}]}], TraditionalForm]], "InlineMath",ExpressionUUID->
  "0072fa17-359d-42fd-93f9-89808dc68347"],
 " are the spectral expansion coefficients and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["d", 
     RowBox[{"m", ",", "n"}], "\[ScriptL]"], "(", "\[Theta]", ")"}], 
   TraditionalForm]], "InlineMath",ExpressionUUID->
  "ca2679a8-1056-4d84-bffb-daabcb091f21"],
 " are the Wigner-d functions which follow the convention that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubsuperscriptBox["d", 
      RowBox[{"m", ",", "n"}], "\[ScriptL]"], "(", "\[Theta]", ")"}], 
    "\[LongEqual]"}], TraditionalForm]], "InlineMath",ExpressionUUID->
  "3c89930b-5cb1-45b4-9a15-c125eb7c7983"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["WignerD",
    BaseStyle->"Link"], "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"\[ScriptL]", ",", 
      RowBox[{"-", 
       StyleBox["m", "TI"]}], ",", 
      RowBox[{"-", 
       StyleBox["n", "TI"]}]}], "}"}], ",", "0", ",", 
    StyleBox["\[Theta]", "TR"], ",", "0"}], "]"}]],ExpressionUUID->
  "3bf0996c-cfd2-4023-b3ab-083c52b78d3c"],
 ".  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Eta]", "=", "0"}], TraditionalForm]], "InlineMath",
  ExpressionUUID->"c8daee7d-8650-4d85-bc21-a3791606fd21"],
 " if ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]], "InlineMath",ExpressionUUID->
  "c369fad5-19d7-4d71-a690-4bb4262f31a0"],
 " is an integer, but ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Eta]", "=", 
    FractionBox["1", "2"]}], TraditionalForm]], "InlineMath",ExpressionUUID->
  "69e64a22-69e3-43c0-8591-644701c491df"],
 " if ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]], "InlineMath",ExpressionUUID->
  "b34c44ea-7c1a-416a-9e6b-496c6c450f30"],
 " is a half-odd integer to guarantee that the function is real in the \
spherical limit."
}], "Text",
 CellChangeTimes->{{3.879779706321827*^9, 3.879779914892647*^9}, 
   3.882521037044379*^9, {3.882521097561846*^9, 3.882521286373932*^9}, {
   3.916133401869975*^9, 3.916133518251966*^9}},
 CellID->1389282908,ExpressionUUID->"83c289c1-ee73-492f-8687-20dad7eda385"],

Cell[BoxData[GridBox[{
   {
    ButtonBox["SpinWeightedSpheroidal",
     BaseStyle->"Link",
     ButtonData->"paclet:SWSpheroidal/ref/SpinWeightedSpheroidal"], Cell["\<\
Solves a discete version of the angular Teukolsky equation and a set of \
eigenvalues and associated spectral expansion coefficients\
\>", "TableText",ExpressionUUID->"c20d4a9d-1aac-414a-83ed-d89c3e77a297"]},
   {
    ButtonBox["AngularSpectralRoot",
     BaseStyle->"Link",
     ButtonData->"paclet:SWSpheroidal/ref/AngularSpectralRoot"], Cell[
    TextData[{
     "First calls ",
     Cell[BoxData[
      ButtonBox["SpinWeightedSpheroidal",
       BaseStyle->"Link",
       ButtonData->"paclet:SWSpheroidal/ref/SpinWeightedSpheroidal"]], 
      "InlineFormula",ExpressionUUID->"30e5c3ff-f4b1-419b-aa6b-538f916825cf"],
     
     " and then returns the specific eigensolution whose eigenvalue is \
closest to a specific value"
    }], "TableText",ExpressionUUID->"2ac12fb0-7c68-4bbc-bb89-c200fafd7bb4"]},
   {
    ButtonBox["AngularSpectralRootIndex",
     BaseStyle->"Link",
     ButtonData->"paclet:SWSpheroidal/ref/AngularSpectralRootIndex"], Cell[
    TextData[{
     "First calls ",
     Cell[BoxData[
      ButtonBox["SpinWeightedSpheroidal",
       BaseStyle->"Link",
       ButtonData->"paclet:SWSpheroidal/ref/SpinWeightedSpheroidal"]], 
      "InlineFormula",ExpressionUUID->"e7ea1eec-7f1e-47db-80a4-f5964230f911"],
     
     " and then returns a specific eigensolution chosen by its position \
within the set of solutions"
    }], "TableText",ExpressionUUID->"95df1daf-169d-4105-9412-f56c8c542fdf"]},
   {
    ButtonBox["SWSFfixphase",
     BaseStyle->"Link",
     ButtonData->"paclet:SWSpheroidal/ref/SWSFfixphase"], Cell["\<\
Computes a phase factor the can be applied to a set of spectral expansion \
coefficients to yield a desired phase convention for the spin-weighted \
spheroidal functions\
\>", "TableText",ExpressionUUID->"c7433666-04a0-49e7-820f-b7234560fe2a"]},
   {
    ButtonBox["SLCorrectInitialDiscontinuity",
     BaseStyle->"Link",
     ButtonData->"paclet:SWSpheroidal/ref/SLCorrectInitialDiscontinuity"], 
    Cell[TextData[{
     "Used to compute a correct phase factor when an initial discontinuity is \
present.  These initial discontinuities may occur when the eigenfunction in \
the spherical limit vanishes at ",
     Cell[BoxData[
      FormBox[
       RowBox[{"x", "=", "0"}], TraditionalForm]], "InlineMath",
      ExpressionUUID->"6a2bee7e-49e6-4da0-b445-b4877ab8e363"],
     "."
    }], "TableText",ExpressionUUID->"a6695185-04f9-43e8-aa56-ebd51fe763e8"]},
   {
    ButtonBox["SLCorrectExtremumDiscontinuity",
     BaseStyle->"Link",
     ButtonData->"paclet:SWSpheroidal/ref/SLCorrectExtremumDiscontinuity"], 
    Cell[TextData[{
     "Corrects a list of complex phase factors created by ",
     Cell[BoxData[
      ButtonBox["SWSFfixphase",
       BaseStyle->"Link",
       ButtonData->"paclet:SWSpheroidal/ref/SWSFfixphase"]], "InlineFormula",
      ExpressionUUID->"96374ea4-ed77-49ac-a0f5-ab71c91bd200"],
     " ensuring that there are no phase-angle discontinuities of \[Pi]  due \
to extrema crossing ",
     Cell[BoxData[
      FormBox[
       RowBox[{"x", "=", "0"}], TraditionalForm]], "InlineMath",
      ExpressionUUID->"dcef05e3-f63d-4358-80e2-fff64cde53d7"],
     "."
    }], "TableText",ExpressionUUID->"036d6e16-2440-4b52-b40a-c5999fb94d81"]},
   {
    ButtonBox["SWSFvalues",
     BaseStyle->"Link",
     ButtonData->"paclet:SWSpheroidal/ref/SWSFvalues"], Cell[TextData[{
     "0Evalueates the spin-wieighted spheroidal function over a set of values \
of ",
     Cell[BoxData[
      FormBox["x", TraditionalForm]], "InlineMath",ExpressionUUID->
      "4d98657d-8264-4198-9a72-3fe2d908fc4b"],
     "."
    }], "TableText",ExpressionUUID->"c1492eb1-df44-440e-bb55-6a68861d5e96"]},
   {
    ButtonBox["SWSFRealPath",
     BaseStyle->"Link",
     ButtonData->"paclet:SWSpheroidal/ref/SWSFRealPath"], Cell["\<\
Determines the path through the complex plane along which the spin-weighted \
spheroidal function remains real.\
\>", "TableText",ExpressionUUID->"7d933580-668d-4123-8c83-9826e3a181b7"]}
  }]], "DefinitionBox",
 CellChangeTimes->{{3.8797758386120043`*^9, 3.8797758576163282`*^9}, {
   3.879775900968107*^9, 3.8797759743164263`*^9}, {3.879776076857537*^9, 
   3.879776096221262*^9}, {3.879776202070159*^9, 3.879776206553998*^9}, {
   3.8797800054190474`*^9, 3.879780092315604*^9}, {3.879780149987471*^9, 
   3.879780308764258*^9}, {3.879780426643273*^9, 3.879780566940683*^9}, {
   3.882027265981805*^9, 3.882027348892473*^9}, {3.882521814095779*^9, 
   3.882521875679703*^9}, {3.882521912062187*^9, 3.882521914649527*^9}, {
   3.8825219786501293`*^9, 3.882521978650161*^9}, {3.882522011314357*^9, 
   3.882522011807753*^9}, {3.92036484268758*^9, 3.920364998834283*^9}, {
   3.9203650768952713`*^9, 3.920365076895328*^9}, {3.920709953680147*^9, 
   3.920709977788128*^9}, {3.920710011871048*^9, 3.9207100983636107`*^9}, {
   3.92071015979749*^9, 3.920710178484996*^9}, {3.9207327708570976`*^9, 
   3.920732838290843*^9}, {3.920732869655868*^9, 3.920732997959956*^9}, 
   3.920733140154132*^9},
 CellID->648815703,ExpressionUUID->"8ecb2166-34a5-48b7-b9f5-3a003202461d"],

Cell["XXXX", "Caption",
 CellChangeTimes->{{3.879776007750808*^9, 3.87977601732627*^9}, {
  3.879782400625483*^9, 3.879782479809857*^9}},
 CellID->1871044502,ExpressionUUID->"fe40afa4-f700-4b39-a22f-5de7bfed7756"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   ButtonBox["SpinWeightedSpheroidal",
    BaseStyle->"Link",
    ButtonData->"paclet:SWSpheroidal/ref/SpinWeightedSpheroidal"], "[", 
   RowBox[{
    StyleBox["m", "TI"], ",", 
    StyleBox["s", "TI"], ",", 
    StyleBox["c", "TI"], ",", 
    StyleBox[
     ButtonBox["N",
      BaseStyle->"Link"],
     FontSlant->"Italic"]}], "]"}]], "InlineFormula",ExpressionUUID->
  "7403b04a-eb1f-425f-be10-9ec4090c8d73"],
 " constructs an ",
 Cell[BoxData[
  FormBox[
   RowBox[{"N", "\[Cross]", "N"}], TraditionalForm]], "InlineMath",
  ExpressionUUID->"862609ea-439a-4544-bf48-a55367015ee1"],
 " pentadiagonal matrix that is a truncated spectral representation of the \
spin-weighted spheroidal eigensystem.  This matrix is passed to ",
 ButtonBox["Eigensystem",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Eigensystem"],
 " which returns it eigenvalues and associated eigenvectors.  The vector of \
eigenvalues returns the first ",
 Cell[BoxData[
  FormBox["N", TraditionalForm]], "InlineMath",ExpressionUUID->
  "d084328a-6954-41e0-8832-6c297f8231c4"],
 " values of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[InvisiblePrefixScriptBase]", "s"], 
     SubscriptBox["A", 
      RowBox[{"\[ScriptL]", ",", "m"}]]}], 
    RowBox[{"(", "c", ")"}]}], TraditionalForm]], "InlineMath",ExpressionUUID->
  "3db86d24-75e9-451b-97a3-4f0c633b78ef"],
 ".  Each associated eigenvector yields the first  ",
 Cell[BoxData[
  FormBox["N", TraditionalForm]], "InlineMath",ExpressionUUID->
  "dba86962-8e8d-48dc-b7f9-7b3cff7169e6"],
 " values of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[InvisiblePrefixScriptBase]", "s"], 
     SubscriptBox["\[ScriptCapitalA]", 
      RowBox[{
       OverscriptBox["\[ScriptL]", "^"], ",", "\[ScriptL]", ",", "m"}]]}], 
    RowBox[{"(", "c", ")"}]}], TraditionalForm]], "InlineMath",ExpressionUUID->
  "8cf17af7-558d-444a-9ba0-e279cce77ea3"],
 " where ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["\[ScriptL]", "^"], TraditionalForm]], "InlineMath",
  ExpressionUUID->"5de2d078-01e5-4589-ba50-01ff213c4ee3"],
 " labels the components of the eigenvector beginning with ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["\[ScriptL]", "^"], "=", 
    RowBox[{"max", "(", 
     RowBox[{
      RowBox[{"\[LeftBracketingBar]", "s", "\[RightBracketingBar]"}], ",", 
      RowBox[{"\[LeftBracketingBar]", "m", "\[RightBracketingBar]"}]}], 
     ")"}]}], TraditionalForm]], "InlineMath",ExpressionUUID->
  "c4f66501-7146-4153-9356-aac30565b24d"],
 "."
}], "Text",
 CellChangeTimes->{{3.8797824757956467`*^9, 3.879782775940237*^9}, {
  3.8797828098520393`*^9, 3.8797828657511578`*^9}, {3.879782924960436*^9, 
  3.879783121751884*^9}, {3.879783176656857*^9, 3.879783206946771*^9}, {
  3.8797833299970837`*^9, 3.879783329999181*^9}, {3.88252165044307*^9, 
  3.882521659830349*^9}, {3.88252169295028*^9, 3.882521784070905*^9}, {
  3.88252196833602*^9, 3.882521971461553*^9}, {3.882522031815013*^9, 
  3.882522034983472*^9}, {3.959417511967533*^9, 3.9594175119680567`*^9}},
 CellID->1875745317,ExpressionUUID->"3514a1f7-8c27-4ccf-83b0-50b706290549"],

Cell[TextData[{
 "The returned eigenvalues and associated eigenvectors are sorted in order of \
increasing value ",
 StyleBox["of ",
  Deletable->True],
 Cell[BoxData[
  FormBox[
   RowBox[{"|", 
    RowBox[{
     RowBox[{
      RowBox[{
       SubscriptBox["\[InvisiblePrefixScriptBase]", "s"], 
       SubscriptBox["A", 
        RowBox[{"\[ScriptL]", ",", "m"}]]}], 
      RowBox[{"(", "c", ")"}]}], "+", "s"}], "|"}], TraditionalForm]], 
  "InlineMath",ExpressionUUID->"85ef205b-adfe-421e-aa6f-1749ac49878f"],
 ".  This is necessary so that solutions obeying the basic symmetry ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{"s", "\[RightArrow]", 
      RowBox[{"-", "s"}]}], ",", 
     RowBox[{"x", "\[RightArrow]", 
      RowBox[{"-", "x"}]}]}], "}"}], TraditionalForm]], "InlineMath",
  ExpressionUUID->"8201a9ce-5ac6-4624-8cee-af83220d6ba6"],
 " of the spin-weighted spheroidal eigensystem are guaranteed to have \
corresponding eigenvalues sorted into the same order."
}], "Text",
 CellChangeTimes->{{3.8797824757956467`*^9, 3.879782775940237*^9}, {
  3.8797828098520393`*^9, 3.8797828657511578`*^9}, {3.879782924960436*^9, 
  3.879783121751884*^9}, {3.879783176656857*^9, 3.879783206946771*^9}, {
  3.8797833299970837`*^9, 3.879783329999181*^9}, {3.88252165044307*^9, 
  3.882521659830349*^9}, {3.88252169295028*^9, 3.882521784070905*^9}, {
  3.88252196833602*^9, 3.882521971461553*^9}, {3.882522031815013*^9, 
  3.882522034983472*^9}, {3.959417537185661*^9, 3.959417679679617*^9}, {
  3.959417736178856*^9, 3.9594179668264728`*^9}, {3.961084395470915*^9, 
  3.9610844242949553`*^9}},
 CellID->1787022361,ExpressionUUID->"d34587ec-345f-4899-bf25-46de27af35e7"],

Cell[TextData[{
 "Because the spectral representation of the spin-weighted spheroidal \
eigensystem is truncated, the returned eigensolutions will be approximations. \
 The first eigensolution will be the most accurate, the accuracy will \
decrease moving further into the list of solutions, and the accuracy of all \
solutions depends strongly on the value of ",
 StyleBox["N",
  FontSlant->"Italic"],
 ".  The accuracy of each eigensolution can be gauged by looking at the \
magnitudes of the components of its eigenvector."
}], "Text",
 CellChangeTimes->{{3.879783394128809*^9, 3.879783783046479*^9}},
 CellID->1224629921,ExpressionUUID->"c07199ce-8b74-42df-9cc5-afa8da474fcc"],

Cell[TextData[{
 "If the spectral representation of the eigenfunction is in the convergent \
regime, then the magnitudes of the spectral expansion coefficients will \
decrease exponentially with ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["\[ScriptL]", "^"], TraditionalForm]], "InlineMath",
  ExpressionUUID->"8d678afe-6d07-4281-a10d-53e7d3f91e21"],
 " for large values of ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["\[ScriptL]", "^"], TraditionalForm]], "InlineMath",
  ExpressionUUID->"22fb121f-fc41-404a-9a6d-dc329e721862"],
 ".  Furthermore, the magnitude of the largest truncated coefficient sets the \
scale for the error in the eigenfunction."
}], "Text",
 CellChangeTimes->{{3.8797837894291677`*^9, 3.879784118124524*^9}, {
  3.882524191505408*^9, 3.882524194066312*^9}},
 CellID->871809399,ExpressionUUID->"f5391c03-bed3-4117-946f-ececcd95d8ba"]
}, Open  ]],

Cell[CellGroupData[{

Cell["The Confluent Heun Method", "Section",
 CellChangeTimes->{{3.879776557714272*^9, 3.8797765654156713`*^9}, {
  3.981565937570348*^9, 3.981565943557819*^9}},
 CellID->1168326178,ExpressionUUID->"2e1066ce-e791-4dfc-a4f4-85f90eb50507"],

Cell[TextData[{
 "The spin-weighted spheroidal functions ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[InvisiblePrefixScriptBase]", "s"], 
     SubscriptBox["S", 
      RowBox[{"\[ScriptL]", ",", "m"}]]}], 
    RowBox[{"(", 
     RowBox[{"x", ",", "c"}], ")"}]}], TraditionalForm]], "InlineMath",
  ExpressionUUID->"c1a34730-e971-4485-b2ea-c55fa1148207"],
 " can be expressed in terms of the confluent Heun functions ",
 ButtonBox["HeunC",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/HeunC"],
 " in several ways.  We choose to express them as"
}], "Text",
 CellChangeTimes->{{3.98156598362381*^9, 3.981566073377932*^9}, {
  3.981566317008219*^9, 3.9815663245004463`*^9}, {3.9815669420197906`*^9, 
  3.981566942242835*^9}},
 CellID->725563543,ExpressionUUID->"36d8f177-a658-4632-a625-6b191ae106ce"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      SubscriptBox["\[InvisiblePrefixScriptBase]", "s"], 
      SubscriptBox["S", 
       RowBox[{"\[ScriptL]", ",", "m"}]]}], 
     RowBox[{"(", 
      RowBox[{"x", ",", "c"}], ")"}]}], "\[LongEqual]", 
    RowBox[{
     SuperscriptBox["e", 
      RowBox[{"\[PlusMinus]", "cx"}]], 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"1", "-", "x"}], ")"}], 
      FractionBox[
       RowBox[{"\[LeftBracketingBar]", 
        RowBox[{"m", "+", "s"}], "\[RightBracketingBar]"}], "2"]], " ", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"1", "+", "x"}], ")"}], 
      FractionBox[
       RowBox[{"\[LeftBracketingBar]", 
        RowBox[{"m", "-", "s"}], "\[RightBracketingBar]"}], "2"]], 
     RowBox[{"HeunC", "[", 
      RowBox[{
      "q", ",", "\[Alpha]", ",", "\[Gamma]", ",", "\[Delta]", ",", 
       "\[Epsilon]", ",", "z"}], "]"}]}]}], TraditionalForm]], "InlineMath",
  ExpressionUUID->"765e0bf2-9618-4739-8d57-6e09e19af0ec"],
 ","
}], "DisplayMath",
 CellChangeTimes->{{3.882520808294332*^9, 3.882520933620928*^9}, {
  3.915898062091734*^9, 3.915898062091777*^9}, {3.9159767950127907`*^9, 
  3.915976795012829*^9}, {3.981566108887855*^9, 3.9815663055808887`*^9}, {
  3.981566336826029*^9, 3.981566336826118*^9}},
 CellID->508724808,ExpressionUUID->"3a1c83c3-9a8c-4fff-bd50-5827b3521847"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox["q", TraditionalForm]], "InlineMath",ExpressionUUID->
  "eb97aed8-5fb7-43f2-b955-02d9b48ea2c5"],
 ", ",
 Cell[BoxData[
  FormBox["\[Alpha]", TraditionalForm]], "InlineMath",ExpressionUUID->
  "75b4b2f9-98de-4a04-bb42-57abdbdc5717"],
 ", ",
 Cell[BoxData[
  FormBox["\[Gamma]", TraditionalForm]], "InlineMath",ExpressionUUID->
  "f7e3b746-457c-4f8c-bb03-9c3799487e14"],
 ", ",
 Cell[BoxData[
  FormBox["\[Delta]", TraditionalForm]], "InlineMath",ExpressionUUID->
  "65993ed0-1bd1-478d-a2fc-1564fa639e32"],
 ", and ",
 Cell[BoxData[
  FormBox["\[Epsilon]", TraditionalForm]], "InlineMath",ExpressionUUID->
  "820f627b-ab9c-44a5-a3d0-1db0f192d94d"],
 " are functions of ",
 Cell[BoxData[
  FormBox["s", TraditionalForm]], "InlineMath",ExpressionUUID->
  "78092709-573a-4114-b9c2-a9112108d4eb"],
 ", ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]], "InlineMath",ExpressionUUID->
  "56c4d88f-e92b-43e6-a9bf-e1a9bbb7e18e"],
 ", ",
 Cell[BoxData[
  FormBox["c", TraditionalForm]], "InlineMath",ExpressionUUID->
  "9de93d71-5d54-4286-8347-3102bd91e9f9"],
 ", and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[InvisiblePrefixScriptBase]", "s"], 
    SubscriptBox["A", 
     RowBox[{"\[ScriptL]", ",", "m"}]]}], TraditionalForm]], "InlineMath",
  ExpressionUUID->"fd41877d-4458-47f9-945b-5f31e3088eff"],
 ".  Also, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"z", "=", 
    FractionBox[
     RowBox[{"1", "-", "x"}], "2"]}], TraditionalForm]], "InlineMath",
  ExpressionUUID->"c6cac1f6-c79b-43c2-b00a-98f8726c7068"],
 " for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"-", "1"}], "<", "x", "\[LessEqual]", "1"}], TraditionalForm]], 
  "InlineMath",ExpressionUUID->"c0a5e5e1-03e8-4ffe-a12f-dc7e546a7290"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"z", "=", 
    FractionBox[
     RowBox[{"1", "+", "x"}], "2"]}], TraditionalForm]], "InlineMath",
  ExpressionUUID->"fc8e8e0b-927c-4683-9ba0-5154bdb46a09"],
 " for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"-", "1"}], "\[LessEqual]", "x", "<", "1"}], TraditionalForm]], 
  "InlineMath",ExpressionUUID->"dbebadab-fba4-45bb-99a6-cf3bd8036b64"],
 "."
}], "Text",
 CellChangeTimes->{{3.9815663928117456`*^9, 3.9815666132900543`*^9}, {
  3.9815669959337893`*^9, 3.9815669959350033`*^9}},
 CellID->2077067772,ExpressionUUID->"3a13ee8c-7ec1-4bf9-96a5-90f97d7a3d0f"],

Cell[TextData[{
 "Mathematica's confluent Heun function ",
 ButtonBox["HeunC",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/HeunC"],
 " evaluates to one at the regular singular point ",
 Cell[BoxData[
  FormBox[
   RowBox[{"z", "=", "0"}], TraditionalForm]], "InlineMath",ExpressionUUID->
  "217efa78-610e-4895-83e3-ee048abcac66"],
 ", but are ",
 ButtonBox["Indeterminate",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Indeterminate"],
 " at the regular singular point ",
 Cell[BoxData[
  FormBox[
   RowBox[{"z", "=", "1"}], TraditionalForm]], "InlineMath",ExpressionUUID->
  "000f8f86-e7df-4547-986e-602c4cfcf14c"],
 ".  Regular local ",
 StyleBox["Frobenious",
  IgnoreSpellCheck->True],
 " solutions at both the regular singular points of the angular Teukolsky \
equation at ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "=", 
    RowBox[{"\[PlusMinus]", "1"}]}], TraditionalForm]], "InlineMath",
  ExpressionUUID->"692d8c0c-86a2-4c17-9b66-5a8f5975c97a"],
 " can be constructed from HeunC.  In fact, 8 different solutions can be \
constructed at each point.  At x=+1, 4 of the solutions can be written as:"
}], "Text",
 CellChangeTimes->{{3.9815663928117456`*^9, 3.9815666132900543`*^9}, {
  3.981566997075536*^9, 3.981567220322131*^9}, {3.981619607694396*^9, 
  3.9816198465318108`*^9}},
 CellID->1473424439,ExpressionUUID->"ec78bd82-9566-4ab3-9c90-c37e4ae7c08b"],

Cell[CellGroupData[{

Cell[TextData[{
 "Regular solutions at ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "=", 
    RowBox[{"+", "1"}]}], TraditionalForm]], "InlineMath",ExpressionUUID->
  "a3729822-b8e4-4bd7-bba8-ad44ea753bbf"]
}], "Subsection",
 CellChangeTimes->{
  3.981619862261105*^9, {3.9816199937998667`*^9, 3.981620008480575*^9}},
 CellID->629639484,ExpressionUUID->"3511cea7-dd58-4752-86fc-87a438d9ff1e"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{
     SubscriptBox["\[InvisiblePrefixScriptBase]", "s"], 
     SubscriptBox["S", 
      RowBox[{"\[ScriptL]", ",", "m"}]]}], 
    RowBox[{"(", 
     RowBox[{"x", ",", "c"}], ")"}]}], "\[LongEqual]", 
   RowBox[{
    SuperscriptBox["e", "cx"], 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"1", "-", "x"}], ")"}], 
     FractionBox[
      RowBox[{"m", "+", "s"}], "2"]], " ", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"1", "+", "x"}], ")"}], 
     FractionBox[
      RowBox[{"m", "-", "s"}], "2"]], 
    RowBox[{
     ButtonBox["HeunC",
      BaseStyle->"Link",
      ButtonData->"paclet:ref/HeunC"], "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         SubscriptBox["\[InvisiblePrefixScriptBase]", "s"], 
         SubscriptBox["A", 
          RowBox[{"\[ScriptL]", ",", "m"}]]}], 
        RowBox[{"(", "c", ")"}]}], "+", 
       SuperscriptBox["c", "2"], "-", 
       RowBox[{"2", " ", "c", " ", 
        RowBox[{"(", 
         RowBox[{"m", "+", 
          RowBox[{"2", " ", "s"}], "+", "1"}], ")"}]}], "-", 
       RowBox[{"m", " ", 
        RowBox[{"(", 
         RowBox[{"m", "+", "1"}], ")"}]}], "+", 
       RowBox[{"s", "(", 
        RowBox[{"s", "+", "1"}], ")"}]}], ",", 
      RowBox[{
       RowBox[{"-", "4"}], " ", "c", " ", 
       RowBox[{"(", 
        RowBox[{"m", "+", "s", "+", "1"}], ")"}]}], ",", 
      RowBox[{"m", "+", "s", "+", "1"}], ",", 
      RowBox[{"m", "-", "s", "+", "1"}], ",", 
      RowBox[{
       RowBox[{"-", "4"}], " ", "c"}], ",", 
      FractionBox[
       RowBox[{"1", "-", "x"}], "2"]}], "]"}]}]}], 
  TraditionalForm]], \
"EquationNumbered",ExpressionUUID->"56d7b8d6-1ec4-4387-9733-265245382289"]], \
"ItemNumbered",
 CellChangeTimes->{{3.981620076446488*^9, 3.981620100290265*^9}, {
  3.981620198032411*^9, 3.9816202268415337`*^9}, {3.981621157656927*^9, 
  3.981621157656971*^9}},
 CellID->972953392,ExpressionUUID->"9c3e3f51-4dff-4da3-8b9e-92b5d004c622"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{
     SubscriptBox["\[InvisiblePrefixScriptBase]", "s"], 
     SubscriptBox["S", 
      RowBox[{"\[ScriptL]", ",", "m"}]]}], 
    RowBox[{"(", 
     RowBox[{"x", ",", "c"}], ")"}]}], "\[LongEqual]", 
   RowBox[{
    SuperscriptBox["e", "cx"], 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"1", "-", "x"}], ")"}], 
     FractionBox[
      RowBox[{"m", "+", "s"}], "2"]], " ", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"1", "+", "x"}], ")"}], 
     RowBox[{"-", 
      FractionBox[
       RowBox[{"m", "-", "s"}], "2"]}]], 
    RowBox[{
     ButtonBox["HeunC",
      BaseStyle->"Link",
      ButtonData->"paclet:ref/HeunC"], "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         SubscriptBox["\[InvisiblePrefixScriptBase]", "s"], 
         SubscriptBox["A", 
          RowBox[{"\[ScriptL]", ",", "m"}]]}], 
        RowBox[{"(", "c", ")"}]}], "+", 
       SuperscriptBox["c", "2"], "-", 
       RowBox[{"2", "c", " ", 
        RowBox[{"(", 
         RowBox[{"m", "+", 
          RowBox[{"2", " ", "s"}], "+", "1"}], ")"}]}]}], ",", 
      RowBox[{
       RowBox[{"-", "4"}], "c", " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"2", " ", "s"}], "+", "1"}], ")"}]}], ",", 
      RowBox[{"m", "+", "s", "+", "1"}], ",", 
      RowBox[{"s", "-", "m", "+", "1"}], ",", 
      RowBox[{
       RowBox[{"-", "4"}], " ", "c"}], ",", 
      FractionBox[
       RowBox[{"1", "-", "x"}], "2"]}], "]"}]}]}], 
  TraditionalForm]], \
"EquationNumbered",ExpressionUUID->"4be4a8a0-df9b-4540-a9d3-5d111808d780"]], \
"ItemNumbered",
 CellChangeTimes->{{3.981620076446488*^9, 3.981620100290265*^9}, {
  3.981620198032411*^9, 3.9816202268415337`*^9}, {3.9816208302168427`*^9, 
  3.981620854108418*^9}, {3.981621163122278*^9, 3.9816211631223307`*^9}},
 CellID->1421452524,ExpressionUUID->"257115f5-14a7-461d-8336-0d8a47ed8da8"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{
     SubscriptBox["\[InvisiblePrefixScriptBase]", "s"], 
     SubscriptBox["S", 
      RowBox[{"\[ScriptL]", ",", "m"}]]}], 
    RowBox[{"(", 
     RowBox[{"x", ",", "c"}], ")"}]}], "\[LongEqual]", 
   RowBox[{
    SuperscriptBox["e", "cx"], 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"1", "-", "x"}], ")"}], 
     RowBox[{"-", 
      FractionBox[
       RowBox[{"m", "+", "s"}], "2"]}]], " ", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"1", "+", "x"}], ")"}], 
     RowBox[{"-", 
      FractionBox[
